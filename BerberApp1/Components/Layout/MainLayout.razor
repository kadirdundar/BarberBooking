@implements IDisposable
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using BerberApp1.Data

<div class="page">
    @if (!ShouldHideNavbar())
    {
        <header class="main-header">
            <div class="header-content">
                <div class="header-left">
                    <NavLink href="/" class="logo">
                        <div class="logo-icon"><i class="fas fa-calendar-check"></i></div>
                        <span class="logo-text">Bookify</span>
                    </NavLink>
                    
                    <ul class="nav-menu @(mobileMenuOpen ? "show" : "")" id="navMenu">
                        <li class="nav-item">
                            <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">
                                Keşfet
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/business" class="nav-link">
                                İşletmeler İçin
                            </NavLink>
                        </li>
                        @if (UserSalonId.HasValue)
                        {
                            <li class="nav-item">
                                <NavLink href="@($"/employee-timeline/{UserSalonId.Value}")" class="nav-link dashboard-nav-btn">
                                    <i class="fas fa-sliders-h"></i> Yönetim Paneli
                                </NavLink>
                            </li>
                        }
                    </ul>
                </div>
                
                <div class="header-right">
                    <UserProfile />
                    <div class="mobile-menu-toggle" @onclick="ToggleMobileMenu">
                        <i class="fas fa-bars"></i>
                    </div>
                </div>
            </div>
        </header>
    }

    <main class="main-container @(IsFullWidthPage() ? "no-padding" : "")">
        @Body
    </main>

    <div id="blazor-error-ui" data-nosnippet>
        <i class="fas fa-exclamation-triangle"></i>
        Beklenmeyen bir hata oluştu. Lütfen sayfayı yenileyin.
        <a href="." class="reload">
            <i class="fas fa-redo"></i>
            Yenile
        </a>
        <span class="dismiss" @onclick="DismissError">
            <i class="fas fa-times"></i>
        </span>
    </div>
</div>

@code {
    private bool mobileMenuOpen = false;
    private bool IsAuthenticated { get; set; }
    private int? UserSalonId { get; set; }

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = default!;
    [Inject] private IDbContextFactory<ApplicationDbContext> DbContextFactory { get; set; } = default!;
    [Inject] public IJSRuntime? JSRuntime { get; set; }

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        IsAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        await CheckUserSalonAsync(authState.User);
        AuthenticationStateProvider.AuthenticationStateChanged += HandleAuthenticationStateChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private async void HandleAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        IsAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        await CheckUserSalonAsync(authState.User);
        await InvokeAsync(StateHasChanged);
    }

    private bool ShouldHideNavbar()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();
        var queryIndex = relativePath.IndexOf('?');
        if (queryIndex >= 0)
        {
            relativePath = relativePath.Substring(0, queryIndex);
        }
        return relativePath.StartsWith("salon/") || 
               relativePath.StartsWith("booking/") || 
               relativePath.StartsWith("booking-confirmation");
    }

    private bool IsFullWidthPage()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();
        var queryIndex = relativePath.IndexOf('?');
        if (queryIndex >= 0)
        {
            relativePath = relativePath.Substring(0, queryIndex);
        }
        return string.IsNullOrEmpty(relativePath) || 
               relativePath == "business" || 
               relativePath.StartsWith("salon/") || 
               relativePath.StartsWith("booking/") || 
               relativePath.StartsWith("booking-confirmation");
    }

    private async Task CheckUserSalonAsync(ClaimsPrincipal user)
    {
        if (IsAuthenticated && user != null)
        {
            var googleId = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(googleId))
            {
                using var dbContext = await DbContextFactory.CreateDbContextAsync();
                var dbUser = await dbContext.Users
                    .Include(u => u.Salons)
                    .FirstOrDefaultAsync(u => u.GoogleId == googleId);
                if (dbUser != null && dbUser.Salons.Any())
                {
                    UserSalonId = dbUser.Salons.First().Id;
                    return;
                }
            }
        }
        UserSalonId = null;
    }

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }

    private async Task DismissError()
    {
        if (JSRuntime is not null)
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('blazor-error-ui').style.display = 'none';");
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        AuthenticationStateProvider.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }
}
