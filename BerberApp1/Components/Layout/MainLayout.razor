@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization


<div class="page">
    <header class="main-header">
        <div class="header-content">
            <NavLink href="/" class="logo">
                <div class="logo-icon"><i class="fas fa-cut"></i></div>
                <span class="logo-text">BarberBooking</span>
            </NavLink>
            
            <nav class="d-flex align-items-center">
                @if (ShouldShowNav())
                {
                     <ul class="nav-menu @(mobileMenuOpen ? "show" : "")" id="navMenu">
                        <li class="nav-item">
                            <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">
                                Ana Sayfa
                            </NavLink>
                        </li> </ul>
                        @*
                        <li class="nav-item">
                            <NavLink href="/randevu" class="nav-link">
                                Randevu Al
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/randevularim" class="nav-link">
                                Randevularım
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/salon-management/1" class="nav-link">
                                Salon Yönetimi
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink href="/employee-timeline/1" class="nav-link">
                                Zaman Çizelgesi
                            </NavLink>
                        </li>
                    </ul> *@
                }
                <div class="ms-auto me-3">
                    <UserProfile />
                </div>
                <div class="mobile-menu-toggle" @onclick="ToggleMobileMenu">
                    <i class="fas fa-bars"></i>
                </div>
            </nav>
        </div>
    </header>

    <main class="main-container">
        @Body
    </main>

    <div id="blazor-error-ui" data-nosnippet>
        <i class="fas fa-exclamation-triangle"></i>
        Beklenmeyen bir hata oluştu. Lütfen sayfayı yenileyin.
        <a href="." class="reload">
            <i class="fas fa-redo"></i>
            Yenile
        </a>
        <span class="dismiss" @onclick="DismissError">
            <i class="fas fa-times"></i>
        </span>
    </div>
</div>

@code {
    private bool mobileMenuOpen = false;

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = default!;

    private bool IsAuthenticated { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        IsAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        AuthenticationStateProvider.AuthenticationStateChanged += HandleAuthenticationStateChanged;
    }

    private async void HandleAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        IsAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        await InvokeAsync(StateHasChanged);
    }

    private bool ShouldShowNav()
    {
        if (NavigationManager == null)
        {
            return false;
        }
        var uri = new Uri(NavigationManager.Uri, UriKind.Absolute);
        return IsAuthenticated && uri.AbsolutePath != "/";
    }

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }

    [Inject] public IJSRuntime? JSRuntime { get; set; }

    private async Task DismissError()
    {
        if (JSRuntime is not null)
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('blazor-error-ui').style.display = 'none';");
        }
    }
}
