@using Microsoft.Extensions.Logging
@using BerberApp1.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@inject ILogger<Booking> Logger
@inject ApplicationDbContext DbContext
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<div class="booking-container-new">
    <VerticalStepper CurrentStep="@currentStep" Steps="@steps" IsHorizontal="true" />

    @* Step 1: Employee & Service Selection *@
    @if (currentStep == 1)
    {
        <div class="selection-container">
            <div class="step-content employee-selection-container">
                <h4 class="step-title">1. Çalışan Seçimi</h4>
                <div class="employee-avatars">
                    @if (CurrentSalon?.Employees != null)
                    {
                        @foreach (var employee in CurrentSalon.Employees)
                        {
                            <div class="employee-avatar @(selectedEmployeeId == employee.Id ? "selected" : "")" @onclick="() => SelectEmployee(employee.Id)">
                                <img src="@(string.IsNullOrEmpty(employee.PictureUrl) ? "images/barber.png" : employee.PictureUrl)" alt="@employee.Name" />
                                <span>@employee.Name</span>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="step-content service-selection-container">
                <h4 class="step-title">2. Hizmet Seçimi</h4>
                <div class="service-buttons">
                    @foreach (var service in services)
                    {
                        var buttonStyle = selectedServices.Contains(service) ? "background-color: #FFD700; color: #000; border-color: #FFD700;" : "background-color: #fff; border: 1px solid #FFD700; color: #FFD700;";
                        <button class="btn" style="@buttonStyle" @onclick="() => ToggleServiceSelection(service)">
                            @service.Name
                        </button>
                    }
                </div>
            </div>
            <button class="btn btn-primary continue-btn-large" @onclick="() => GoToStep(2)" disabled="@(selectedEmployeeId == null || !selectedServices.Any())">
                Tarih ve Saat Seç
            </button>
        </div>
    }
    @* Step 2: Date, Time, and Summary *@
    else if (currentStep == 2)
    {
        <div class="date-time-picker-container">
            <div class="picker-header">
                <h4 class="month-display">@currentMonth.ToString("MMMM yyyy")</h4>
                <button class="close-btn" @onclick="() => { /* Add close logic if needed */ }">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="date-scroller">
                <button class="scroll-btn" @onclick="ScrollDateLeft"><i class="fas fa-chevron-left"></i></button>
                <div class="date-list" @ref="dateListElement">
                    @foreach (var day in datePickerDays)
                    {
                        var dateItemStyle = day.Date == selectedDate.Date ? "background-color: #FFD700; color: #000; border-color: #FFD700;" : "";
                        <div class="date-item @GetDayClass(day)" style="@dateItemStyle" @onclick="() => SelectDate(day)">
                            <div class="day-name-short">@day.ToString("ddd")</div>
                            <div class="day-number">@day.Day</div>
                            <div class="availability-indicator @(IsDayAvailable(day) ? "available" : "unavailable")"></div>
                        </div>
                    }
                </div>
                <button class="scroll-btn" @onclick="ScrollDateRight"><i class="fas fa-chevron-right"></i></button>
            </div>

            <div class="time-filter">
                <button class="filter-btn @(timeFilter == "Morning" ? "active" : "")" @onclick='() => SetTimeFilter("Morning")'>Morning</button>
                <button class="filter-btn @(timeFilter == "Afternoon" ? "active" : "")" @onclick='() => SetTimeFilter("Afternoon")'>Afternoon</button>
                <button class="filter-btn @(timeFilter == "Evening" ? "active" : "")" @onclick='() => SetTimeFilter("Evening")'>Evening</button>
            </div>

            <div class="time-scroller">
                <button class="scroll-btn" @onclick="ScrollTimeLeft"><i class="fas fa-chevron-left"></i></button>
                <div class="time-list" @ref="timeListElement">
                    @foreach (var slot in FilteredSlots)
                    {
                        <button class="time-slot-btn @(selectedSlot == slot ? "selected" : "")" @onclick="() => SelectSlot(slot)">
                            @slot
                        </button>
                    }
                </div>
                <button class="scroll-btn" @onclick="ScrollTimeRight"><i class="fas fa-chevron-right"></i></button>
            </div>

            <div class="selection-summary">
                @foreach (var service in selectedServices)
                {
                    <div class="service-details">
                        <div class="service-name-price">
                            <span>@service.Name</span>
                            <strong>@service.Price.ToString("C")</strong>
                        </div>
                        <div class="service-duration">
                            @GetAppointmentEndTime(service)
                        </div>
                    </div>
                }
                <div class="staff-preference">
                    <span>Staff: @(CurrentSalon?.Employees.FirstOrDefault(e => e.Id == selectedEmployeeId)?.Name ?? "No preference")</span>
                    <button class="change-btn" @onclick="() => GoToStep(1)">Change</button>
                </div>
            </div>

            <div class="add-service">
                <a href="#" @onclick:preventDefault @onclick="() => GoToStep(1)"><i class="fas fa-plus"></i> Add another service</a>
            </div>

            <div class="footer-summary">
                <div class="total-price">
                    <span>Total:</span>
                    <strong>@selectedServices.Sum(s => s.Price).ToString("C")</strong>
                </div>
                <div class="total-duration">
                    @selectedServices.Sum(s => s.DurationInMinutes)min
                </div>
                <button class="btn btn-primary continue-btn" @onclick="ConfirmAppointment" disabled="@(string.IsNullOrEmpty(selectedSlot))">
                    Randevu Oluştur
                </button>
            </div>
        </div>
    }
</div>


@code {
    private int currentStep = 1;
    private readonly Dictionary<int, string> steps = new()
    {
        { 1, "Seçim" },
        { 2, "Onay" }
    };
    private DateTime currentMonth = DateTime.Today;
    private DateTime selectedDate = DateTime.Today;
    private string selectedSlot = string.Empty;
    private List<string> availableSlots = new List<string>();
    private List<DateTime> datePickerDays = new List<DateTime>();
    private ElementReference dateListElement;
    private ElementReference timeListElement;
    private Dictionary<DateTime, bool> dayAvailability = new Dictionary<DateTime, bool>();
    private bool jsInteropReady = false;

    [Parameter]
    public int SalonId { get; set; }
    private Salon? CurrentSalon { get; set; }
    private List<Service> services = new();
    private List<Service> selectedServices = new();
    private int? selectedEmployeeId;

    private string timeFilter = "Morning";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (currentStep == 2 && !jsInteropReady)
        {
            jsInteropReady = true; // Set flag to prevent re-initialization
            await JSRuntime.InvokeVoidAsync("bookingInterop.enableDragScroll", dateListElement);
            await JSRuntime.InvokeVoidAsync("bookingInterop.enableDragScroll", timeListElement);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CurrentSalon = await DbContext.Salons
                                    .AsNoTracking()
                                    .Include(s => s.Services)
                                    .Include(s => s.Employees)
                                    .Include(s => s.WorkingHours)
                                    .FirstOrDefaultAsync(s => s.Id == SalonId);

        if (CurrentSalon != null)
        {
            services = CurrentSalon.Services.ToList();
        }
        else
        {
            Logger.LogWarning("Salon with ID {SalonId} not found.", SalonId);
            return;
        }

        GenerateDatePickerDays();
        await CheckDaysAvailability();
        await GenerateAvailableSlots(selectedDate);
    }

    private void GenerateDatePickerDays()
    {
        datePickerDays.Clear();
        for (int i = 0; i < 30; i++)
        {
            datePickerDays.Add(DateTime.Today.AddDays(i));
        }
    }

    private async Task CheckDaysAvailability()
    {
        dayAvailability.Clear();
        foreach (var day in datePickerDays)
        {
            dayAvailability[day.Date] = await IsDayActuallyAvailable(day);
        }
    }

    private async Task<bool> IsDayActuallyAvailable(DateTime date)
    {
        if (CurrentSalon == null || !selectedEmployeeId.HasValue || !selectedServices.Any()) return false;

        var workingHours = CurrentSalon.WorkingHours.FirstOrDefault(wh => wh.DayOfWeek == date.DayOfWeek);
        if (workingHours == null || workingHours.IsClosed) return false;

        // This is a simplified check. For a real-world scenario, you'd check for at least one available slot.
        return true;
    }

    private bool IsDayAvailable(DateTime day)
    {
        return dayAvailability.TryGetValue(day.Date, out bool isAvailable) && isAvailable;
    }

    private async Task SelectEmployee(int employeeId)
    {
        selectedEmployeeId = employeeId;
        await CheckDaysAvailability();
        await GenerateAvailableSlots(selectedDate);
        StateHasChanged();
    }

    private async Task ToggleServiceSelection(Service service)
    {
        if (selectedServices.Contains(service))
        {
            selectedServices.Remove(service);
        }
        else
        {
            selectedServices.Add(service);
        }
        await CheckDaysAvailability();
        await GenerateAvailableSlots(selectedDate);
    }

    private async Task SelectDate(DateTime date)
    {
        selectedDate = date;
        await GenerateAvailableSlots(date);
        StateHasChanged();
    }

    private void SelectSlot(string slot)
    {
        selectedSlot = slot;
    }

    private void SetTimeFilter(string filter)
    {
        timeFilter = filter;
    }

    private List<string> FilteredSlots
    {
        get
        {
            if (!availableSlots.Any()) return new List<string>();

            return availableSlots.Where(slot =>
            {
                var time = TimeOnly.Parse(slot);
                return timeFilter switch
                {
                    "Morning" => time.Hour < 12,
                    "Afternoon" => time.Hour >= 12 && time.Hour < 18,
                    "Evening" => time.Hour >= 18,
                    _ => true
                };
            }).ToList();
        }
    }

    private async Task GenerateAvailableSlots(DateTime date)
    {
        availableSlots.Clear();
        if (CurrentSalon == null || !selectedEmployeeId.HasValue || !selectedServices.Any())
        {
            StateHasChanged();
            return;
        }

        var workingHours = CurrentSalon.WorkingHours.FirstOrDefault(wh => wh.DayOfWeek == date.DayOfWeek);
        if (workingHours == null || workingHours.IsClosed)
        {
            StateHasChanged();
            return;
        }

        var existingAppointments = await DbContext.Appointments
            .Include(a => a.AppointmentServices)
            .ThenInclude(aps => aps.Service)
            .Where(a => a.EmployeeId == selectedEmployeeId && a.AppointmentDate.Date == date.Date)
            .OrderBy(a => a.AppointmentTime)
            .ToListAsync();

        int totalDuration = selectedServices.Sum(s => s.DurationInMinutes);
        TimeOnly slotTime = workingHours.OpeningTime;

        while (slotTime.AddMinutes(totalDuration) <= workingHours.ClosingTime)
        {
            bool isSlotAvailable = true;
            TimeOnly slotEndTime = slotTime.AddMinutes(totalDuration);

            foreach (var appointment in existingAppointments)
            {
                TimeOnly appointmentStart = TimeOnly.FromTimeSpan(appointment.AppointmentTime);
                int appointmentDuration = appointment.AppointmentServices.Sum(aps => aps.Service.DurationInMinutes);
                TimeOnly appointmentEnd = appointmentStart.AddMinutes(appointmentDuration);

                // Check for overlap
                if (slotTime < appointmentEnd && slotEndTime > appointmentStart)
                {
                    isSlotAvailable = false;
                    break;
                }
            }

            if (isSlotAvailable)
            {
                availableSlots.Add(slotTime.ToString("HH:mm"));
            }

            slotTime = slotTime.AddMinutes(15); // Check for the next slot every 15 minutes
        }
        StateHasChanged();
    }

    private async Task ConfirmAppointment()
    {
        if (string.IsNullOrEmpty(selectedSlot) || CurrentSalon == null || !selectedServices.Any() || !selectedEmployeeId.HasValue)
        {
            Logger.LogWarning("Appointment confirmation failed due to missing information.");
            return;
        }

        try
        {
            var appointmentTime = TimeSpan.Parse(selectedSlot);
            var newAppointment = new Appointment
            {
                SalonId = CurrentSalon.Id,
                EmployeeId = selectedEmployeeId.Value,
                AppointmentDate = selectedDate.Date,
                AppointmentTime = appointmentTime,
                CustomerName = "Dummy User", // Replace with actual user data
                CustomerPhone = "0000000000", // Replace with actual user data
                Notes = "Randevu sistem üzerinden oluşturuldu."
            };

            foreach (var service in selectedServices)
            {
                newAppointment.AppointmentServices.Add(new AppointmentService { ServiceId = service.Id });
            }

            DbContext.Appointments.Add(newAppointment);
            await DbContext.SaveChangesAsync();

            Logger.LogInformation("Appointment created successfully for {Date} at {Time}", selectedDate.ToShortDateString(), selectedSlot);
            
            NavigationManager.NavigateTo("/booking-confirmation");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating appointment.");
        }
    }

    private string GetDayClass(DateTime day)
    {
        string cssClass = "date-item";
        if (day.Date == DateTime.Today) cssClass += " today";
        if (day.Date == selectedDate.Date) cssClass += " selected";
        return cssClass;
    }

    private string GetAppointmentEndTime(Service service)
    {
        if (TimeSpan.TryParse(selectedSlot, out var startTime))
        {
            var endTime = startTime.Add(TimeSpan.FromMinutes(service.DurationInMinutes));
            return $"{selectedSlot} - {endTime:hh\\:mm}";
        }
        return string.Empty;
    }

    private void GoToStep(int step)
    {
        if (step == 1)
        {
            jsInteropReady = false; // Reset when going back
        }
        currentStep = step;
    }

    private async Task ScrollDateLeft()
    {
        await JSRuntime.InvokeVoidAsync("bookingInterop.scroll", dateListElement, "left");
    }

    private async Task ScrollDateRight()
    {
        await JSRuntime.InvokeVoidAsync("bookingInterop.scroll", dateListElement, "right");
    }

    private async Task ScrollTimeLeft()
    {
        await JSRuntime.InvokeVoidAsync("bookingInterop.scroll", timeListElement, "left");
    }

    private async Task ScrollTimeRight()
    {
        await JSRuntime.InvokeVoidAsync("bookingInterop.scroll", timeListElement, "right");
    }
}
