@using Microsoft.Extensions.Logging
@using BerberApp1.Data
@using Microsoft.EntityFrameworkCore
@inject ILogger<Booking> Logger
@inject ApplicationDbContext DbContext
@rendermode InteractiveServer 


<div class="booking-container">
    <div class="booking-header">
        <h2 class="section-title">@CurrentSalon?.Name İçin Randevu Al</h2>
        <p class="section-subtitle">Tarih ve saat seçerek randevunuzu kolayca oluşturun.</p>
    </div>

    <div class="booking-content">
        <div class="service-selection-container">
            <h4 class="mb-3">Hizmet Seçimi</h4>
            <div class="service-buttons">
                @foreach (var service in services)
                {
                    <button class="btn @(selectedServices.Contains(service) ? "btn-primary" : "btn-outline-primary")" @onclick="() => ToggleServiceSelection(service)">
                        @service.Name
                    </button>
                }
            </div>
        </div>
        <div class="calendar-container">
            <div class="calendar-header">
                <button class="nav-btn" @onclick="PreviousMonth"><i class="fas fa-chevron-left"></i></button>
                <span class="month-display">@currentMonth.ToString("MMMM yyyy")</span>
                <button class="nav-btn" @onclick="NextMonth"><i class="fas fa-chevron-right"></i></button>
            </div>
            <div class="calendar-grid">
                <div class="day-name">Pzt</div>
                <div class="day-name">Sal</div>
                <div class="day-name">Çar</div>
                <div class="day-name">Per</div>
                <div class="day-name">Cum</div>
                <div class="day-name">Cmt</div>
                <div class="day-name">Paz</div>

                @foreach (var day in daysInMonth)
                {
                    <div class="@GetDayClass(day)" @onclick="() => SelectDate(day)">
                        @if (day != DateTime.MinValue)
                        {
                            <span>@day.Day</span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="time-slots-container">
            <h3 class="time-slots-title">Müsait Saatler (@selectedDate.ToShortDateString())</h3>
            @if (availableSlots.Any())
            {
                <div class="time-slots-grid">
                    @foreach (var slot in availableSlots)
                    {
                        <button class="time-slot-btn @(selectedSlot == slot ? "selected" : "")" @onclick="() => SelectSlot(slot)">
                            @slot
                        </button>
                    }
                </div>
                <button class="btn btn-primary confirm-btn" @onclick="ConfirmAppointment" disabled="@(string.IsNullOrEmpty(selectedSlot))">Randevuyu Onayla</button>
            }
            else
            {
                <p>Bu tarih için müsait saat bulunmamaktadır.</p>
            }
        </div>
    </div>
</div>

@code {
    private DateTime currentMonth = DateTime.Today;
    private DateTime selectedDate = DateTime.Today;
    private string selectedSlot = string.Empty;
    private List<DateTime> daysInMonth = new List<DateTime>();
    private List<string> availableSlots = new List<string>();

    [Parameter]
    public int SalonId { get; set; }
    private List<Service> services = new();
    private List<Service> selectedServices = new();
    private Salon? CurrentSalon { get; set; }
    private List<SalonWorkingHours> salonWorkingHours = new();

    protected override async Task OnInitializedAsync()
    {
        CurrentSalon = await DbContext.Salons
                                    .Include(s => s.WorkingHours)
                                    .Include(s => s.Services)
                                    .FirstOrDefaultAsync(s => s.Id == SalonId);

        if (CurrentSalon != null)
        {
            services = CurrentSalon.Services.ToList();
        }

        if (CurrentSalon == null)
        {
            Logger.LogWarning("Salon with ID {SalonId} not found.", SalonId);
            // Optionally, redirect to an error page or display a message
            // NavigationManager.NavigateTo("/error");
            return;
        }
        salonWorkingHours = CurrentSalon.WorkingHours.ToList();

        GenerateCalendar(currentMonth);
        await GenerateAvailableSlots(selectedDate);
    }

    private async Task ToggleServiceSelection(Service service)
    {
        if (selectedServices.Contains(service))
        {
            selectedServices.Remove(service);
        }
        else
        {
            selectedServices.Add(service);
        }
        await GenerateAvailableSlots(selectedDate);
    }

    private void GenerateCalendar(DateTime month)
    {
        daysInMonth.Clear();
        var firstDayOfMonth = new DateTime(month.Year, month.Month, 1);
        int daysInMonthCount = DateTime.DaysInMonth(month.Year, month.Month);
        
        int offset = ((int)firstDayOfMonth.DayOfWeek + 6) % 7; // Monday as first day

        for (int i = 0; i < offset; i++)
        {
            daysInMonth.Add(DateTime.MinValue); // Placeholder for empty days
        }

        for (int i = 1; i <= daysInMonthCount; i++)
        {
            daysInMonth.Add(new DateTime(month.Year, month.Month, i));
        }
    }

    private async Task GenerateAvailableSlots(DateTime date)
    {
        availableSlots.Clear();

        if (CurrentSalon == null || !selectedServices.Any())
        {
            Logger.LogWarning("Cannot generate slots: CurrentSalon is null or no services selected.");
            return;
        }

        var todayWorkingHours = salonWorkingHours.FirstOrDefault(swh => swh.DayOfWeek == date.DayOfWeek);

        if (todayWorkingHours == null || todayWorkingHours.IsClosed)
        {
            return;
        }

        var existingAppointments = await DbContext.Appointments
            .Include(a => a.AppointmentServices)
            .ThenInclude(aps => aps.Service)
            .Where(a => a.SalonId == SalonId && a.AppointmentDate.Date == date.Date)
            .ToListAsync();

        int totalDuration = selectedServices.Sum(s => s.DurationInMinutes);

        TimeOnly minimumAllowedTime = TimeOnly.MinValue;
        if (date.Date == DateTime.Today)
        {
            TimeOnly now = TimeOnly.FromDateTime(DateTime.Now);
            now = new TimeOnly(now.Hour, now.Minute);
            minimumAllowedTime = now;
        }

        TimeOnly currentTime = todayWorkingHours.OpeningTime;
        TimeOnly closingTime = todayWorkingHours.ClosingTime;

        while (currentTime.AddMinutes(totalDuration) <= closingTime)
        {
            bool isSlotAvailable = true;
            if (currentTime < minimumAllowedTime && date.Date == DateTime.Today)
            {
                isSlotAvailable = false;
            }
            else
            {
                foreach (var appointment in existingAppointments)
                {
                    TimeOnly appointmentStart = TimeOnly.FromTimeSpan(appointment.AppointmentTime);
                    int appointmentDuration = appointment.AppointmentServices.Sum(aps => aps.Service.DurationInMinutes);
                    TimeOnly appointmentEnd = appointmentStart.AddMinutes(appointmentDuration);

                    if (currentTime < appointmentEnd && currentTime.AddMinutes(totalDuration) > appointmentStart)
                    {
                        isSlotAvailable = false;
                        break;
                    }
                }
            }

            if (isSlotAvailable)
            {
                availableSlots.Add(currentTime.ToString("HH:mm"));
            }

            currentTime = currentTime.AddMinutes(15); // Check every 15 minutes for a slot
        }
    }

    private async Task SelectDate(DateTime date)
    {
        if (date == DateTime.MinValue || date.Date < DateTime.Today.Date) return; // Disable past dates
        selectedDate = date;
        // Ensure GenerateAvailableSlots is awaited as it's now async
        await GenerateAvailableSlots(date);
        StateHasChanged(); // Explicitly trigger UI re-render
    }

    private void SelectSlot(string slot)
    {
        selectedSlot = slot;
    }

    private async Task ConfirmAppointment()
    {
        if (string.IsNullOrEmpty(selectedSlot) || CurrentSalon == null || !selectedServices.Any())
        {
            Logger.LogWarning("Appointment confirmation failed: No slot selected, salon is null, or no services selected.");
            return;
        }

        try
        {
            var appointmentTime = TimeSpan.Parse(selectedSlot);
            var newAppointment = new Appointment
            {
                SalonId = CurrentSalon.Id,
                AppointmentDate = selectedDate.Date,
                AppointmentTime = appointmentTime,
                CustomerName = "Dummy User",
                CustomerPhone = "0000000000",
                Notes = "Randevu sistem üzerinden oluşturuldu."
            };

            foreach (var service in selectedServices)
            {
                newAppointment.AppointmentServices.Add(new AppointmentService { ServiceId = service.Id });
            }

            DbContext.Appointments.Add(newAppointment);
            await DbContext.SaveChangesAsync();

            Logger.LogInformation("Appointment created successfully for {Date} at {Time}", selectedDate.ToShortDateString(), selectedSlot);
            selectedSlot = string.Empty;
            await GenerateAvailableSlots(selectedDate);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error creating appointment.");
        }
    }

    private void PreviousMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
        GenerateCalendar(currentMonth);
        StateHasChanged();
    }

    private void NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
        GenerateCalendar(currentMonth);
        StateHasChanged();
    }

    private string GetDayClass(DateTime day)
    {
        if (day == DateTime.MinValue) return "day-cell empty";
        string cssClass = "day-cell";
        if (day.Date == DateTime.Today) cssClass += " today";
        if (day.Date == selectedDate.Date) cssClass += " selected";
        if (day.Date < DateTime.Today.Date) cssClass += " disabled"; // Add disabled class for past dates
        if (day.Month != currentMonth.Month) cssClass += " other-month";
        return cssClass;
    }
}


