@page "/business"
@using Microsoft.AspNetCore.Components.Authorization
@using BerberApp1.Data
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ApplicationDbContext DbContext
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore

<PageTitle>Bookify - İşletmenizi Geleceğe Taşıyın</PageTitle>

<div class="landing-container">
    <!-- Hero Section -->
    <header class="hero-section">
        <div class="hero-text fade-in-up">
            <div class="badge-new">İŞLETMELER İÇİN</div>
            <h1 class="hero-title">Rezervasyonlarınızı <span class="text-gradient">Tek Bir Bağlantı</span> İle Yönetin</h1>
            <p class="hero-subtitle">Müşterileriniz için en şık ve hızlı randevu deneyimi. Salon bilgilerinizi ve hizmetlerinizi tek bir profilde toplayın, 7/24 randevu alın.</p>
            
            <div class="claim-bar">
                <span class="claim-prefix">bookify.com/</span>
                <input type="text" class="claim-input" placeholder="salon-adiniz" @bind-value="topSalonName" @bind-value:event="oninput" @onkeydown="@(e => { if (e.Key == "Enter") RedirectToRegisterTop(); })" />
                <button class="claim-btn" @onclick="RedirectToRegisterTop">Hemen Başla</button>
            </div>
            
            <div class="hero-ratings">
                <div class="rating-item">
                    <span class="rating-stars">★★★★★</span>
                    <span class="rating-text">4.9/5 Müşteri Memnuniyeti</span>
                </div>
                <div class="rating-divider">|</div>
                <div class="rating-item">
                    <span class="rating-stats-count">1000+ Aktif İşletme</span>
                </div>
            </div>
        </div>

        <div class="hero-mockup-wrapper">
            <div class="phone-mockup">
                <div class="phone-notch"></div>
                <div class="phone-screen">
                    <div class="phone-avatar">
                        <i class="fas fa-scissors"></i>
                    </div>
                    <h3 class="phone-salon-title">Modern Cut Salon</h3>
                    <div class="phone-salon-badge">✓ Onaylı Partner</div>
                    
                    <div class="phone-links">
                        <div class="phone-link-btn primary">
                            <i class="fas fa-calendar-alt"></i> Online Randevu Al
                        </div>
                        <div class="phone-link-btn">
                            <i class="fas fa-cut"></i> Hizmetler & Fiyatlar
                        </div>
                        <div class="phone-link-btn">
                            <i class="fas fa-map-marker-alt"></i> Yol Tarifi & İletişim
                        </div>
                        <div class="phone-link-btn">
                            <i class="fas fa-images"></i> Galerimiz
                        </div>
                    </div>
                    
                    <div class="phone-footer-socials">
                        <span class="phone-social-icon"><i class="fab fa-instagram"></i></span>
                        <span class="phone-social-icon"><i class="fab fa-facebook-f"></i></span>
                        <span class="phone-social-icon"><i class="fab fa-whatsapp"></i></span>
                    </div>
                </div>
            </div>
            <div class="phone-glow"></div>
        </div>
    </header>

    <!-- Stats Showcase -->
    <section class="stats-showcase">
        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-number">10 Dakika</span>
                <span class="stat-desc">Ortalama Kurulum Süresi</span>
            </div>
            <div class="stat-card">
                <span class="stat-number">%40</span>
                <span class="stat-desc">Telefon Trafiğinde Azalma</span>
            </div>
            <div class="stat-card">
                <span class="stat-number">7/24</span>
                <span class="stat-desc">Kesintisiz Rezervasyon Kabulü</span>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features-section">
        <div class="section-header">
            <h2 class="section-title">Neden <span class="text-gold">Bookify?</span></h2>
            <p class="section-description">İşletmenizi büyütmek ve randevularınızı düzene sokmak için ihtiyacınız olan her şey.</p>
        </div>
        
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h3>Akıllı Randevu Yönetimi</h3>
                <p>Müşterileriniz boş saatlerinizi görsün, anında rezervasyon yapsın. Çift rezervasyon ihtimalini sıfıra indirin.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Müşteri İlişkileri (CRM)</h3>
                <p>Müşterilerinizin geçmiş randevu verilerini, tercihlerini ve harcama detaylarını tek bir ekrandan inceleyin.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-bell"></i>
                </div>
                <h3>Otomatik Hatırlatmalar</h3>
                <p>Randevuya gelmeme veya unutma durumlarını önlemek için otomatik SMS ve bildirimler gönderin.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>Gelişmiş Analitik</h3>
                <p>En çok tercih edilen hizmetleri, çalışan performansını ve günlük ciro raporlarını kolayca takip edin.</p>
            </div>
        </div>
    </section>

    <!-- How It Works Section (Linktree Style Stepper) -->
    <section class="steps-section">
        <div class="section-header">
            <h2 class="section-title">3 Kolay Adımda <span class="text-gradient">Canlıya Alın</span></h2>
            <p class="section-description">Hiçbir teknik bilgiye ihtiyaç duymadan dakikalar içinde randevu almaya başlayın.</p>
        </div>
        
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">1</div>
                <h3 class="step-title">Sayfanızı Oluşturun</h3>
                <p class="step-desc">Kullanıcı adınızı belirleyin, profil görselinizi ve logonuzu yükleyin.</p>
            </div>
            <div class="step-card">
                <div class="step-number">2</div>
                <h3 class="step-title">Hizmetlerinizi Ekleyin</h3>
                <p class="step-desc">Sunduğunuz hizmetleri, süreleri, fiyatları ve çalışan personellerinizi tanımlayın.</p>
            </div>
            <div class="step-card">
                <div class="step-number">3</div>
                <h3 class="step-title">Bağlantınızı Paylaşın</h3>
                <p class="step-desc">Instagram veya TikTok profilinize linkinizi ekleyin ve müşterilerinizin randevu almasını izleyin.</p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="cta-card">
            <div class="cta-glow"></div>
            <div class="cta-content">
                <h2>İşletmenizde Dijital Dönüşümü Başlatın</h2>
                <p>Hemen bugün ücretsiz kaydolun, 30 gün boyunca hiçbir sınır olmadan tüm premium özellikleri deneyimleyin.</p>
                
                <div class="claim-bar bottom-claim">
                    <span class="claim-prefix">bookify.com/</span>
                    <input type="text" class="claim-input" placeholder="salon-adiniz" @bind-value="bottomSalonName" @bind-value:event="oninput" @onkeydown="@(e => { if (e.Key == "Enter") RedirectToRegisterBottom(); })" />
                    <button class="claim-btn" @onclick="RedirectToRegisterBottom">Ücretsiz Başla</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
        <div class="footer-content">
            <div class="footer-brand">
                <h3>Bookify</h3>
                <p>Hizmet ve randevu tabanlı tüm modern işletmeler için link-in-bio yönetim aracı.</p>
            </div>
            <div class="footer-links">
                <a href="#">Hakkımızda</a>
                <a href="#features">Özellikler</a>
                <a href="#">Fiyatlandırma</a>
                <a href="#">Destek</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; @DateTime.Now.Year Bookify. Tüm Hakları Saklıdır.</p>
        </div>
    </footer>
</div>

@code {
    private string topSalonName = "";
    private string bottomSalonName = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is { IsAuthenticated: true })
        {
            var googleId = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(googleId))
            {
                var salon = await DbContext.Salons
                    .FirstOrDefaultAsync(s => s.User != null && s.User.GoogleId == googleId);

                if (salon != null)
                {
                    NavigationManager.NavigateTo($"/employee-timeline/{salon.Id}");
                }
            }
        }
    }

    private void RedirectToRegisterTop()
    {
        RedirectToRegister(topSalonName);
    }

    private void RedirectToRegisterBottom()
    {
        RedirectToRegister(bottomSalonName);
    }

    private void RedirectToRegister(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            NavigationManager.NavigateTo("/register");
        }
        else
        {
            NavigationManager.NavigateTo($"/register?salonName={Uri.EscapeDataString(name)}");
        }
    }
}
