@page "/business"
@using Microsoft.AspNetCore.Components.Authorization
@using BerberApp1.Data
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ApplicationDbContext DbContext
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore

<div class="landing-container">
    <header class="hero-section">
        <div class="hero-overlay"></div>
        <div class="hero-content fade-in-up">
            <h1 class="hero-title">İşletmenizi <span class="text-gradient">Geleceğe</span> Taşıyın</h1>
            <p class="hero-subtitle">Randevu yönetimini basitleştirin, müşteri memnuniyetini artırın ve gelirinizi yükseltin. Güzellik salonları, klinikler, özel eğitmenler, otomotiv servisleri ve tüm hizmet işletmeleri için Bookify yanınızda.</p>
            <div class="hero-buttons">
                <a href="/register" class="btn btn-primary-gold glow-effect">30 Gün Ücretsiz Deneyin</a>
                <a href="#features" class="btn btn-secondary-outline">Özellikleri Keşfet</a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <span class="stat-number">1000+</span>
                    <span class="stat-label">Mutlu İşletme</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">500k+</span>
                    <span class="stat-label">Aylık Randevu</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">4.9</span>
                    <span class="stat-label">Müşteri Puanı</span>
                </div>
            </div>
        </div>
    </header>

    <section id="features" class="features-section">
        <div class="section-header">
            <h2 class="section-title">Neden <span class="text-gold">Bookify?</span></h2>
            <p class="section-description">İşletmenizi büyütmek için ihtiyacınız olan tüm araçlar tek bir platformda.</p>
        </div>
        
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h3>Akıllı Randevu Yönetimi</h3>
                <p>Telefon trafiğine son. Müşterileriniz 7/24 online randevu alsın, takviminiz otomatik güncellensin.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Müşteri İlişkileri</h3>
                <p>Müşteri geçmişini ve tercihlerini takip ederek kişiselleştirilmiş bir hizmet sunun.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-bell"></i>
                </div>
                <h3>Otomatik Hatırlatmalar</h3>
                <p>Randevuya gelmeme oranını SMS ve e-posta hatırlatmaları ile en aza indirin.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-chart-pie"></i>
                </div>
                <h3>Detaylı Raporlama</h3>
                <p>İşletmenizin performansını, en popüler hizmetlerinizi ve çalışan verimliliğini analiz edin.</p>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="cta-content">
            <h2>İşletmenizi Büyütmeye Hazır Mısınız?</h2>
            <p>Binlerce işletme sahibi gibi siz de dijital dönüşüme katılın ve işinizi bir üst seviyeye taşıyın.</p>
            <a href="/register" class="btn btn-light-gold">Hemen Başlayın</a>
        </div>
    </section>

    <footer class="landing-footer">
        <div class="footer-content">
            <div class="footer-brand">
                <h3>Bookify</h3>
                <p>Hizmet ve randevu tabanlı tüm işletmeler için modern yönetim çözümü.</p>
            </div>
            <div class="footer-links">
                <a href="#">Hakkımızda</a>
                <a href="#">Özellikler</a>
                <a href="#">Fiyatlandırma</a>
                <a href="#">İletişim</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; @DateTime.Now.Year Bookify. Tüm Hakları Saklıdır.</p>
        </div>
    </footer>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is { IsAuthenticated: true })
        {
            var googleId = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(googleId))
            {
                var salon = await DbContext.Salons
                    .FirstOrDefaultAsync(s => s.User != null && s.User.GoogleId == googleId);

                if (salon != null)
                {
                    NavigationManager.NavigateTo($"/employee-timeline/{salon.Id}");
                }
            }
        }
    }
}
