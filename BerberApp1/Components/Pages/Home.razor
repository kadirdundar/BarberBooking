@page "/"

<PageTitle>Ana Sayfa - BarberBooking</PageTitle>

 <section class="hero-section">
        <div class="hero-content">
            <h1 class="hero-title">Salonunuzu Dijitalleştirin.Mükemmel Müşteri Deneyimi Yaratın!</h1>
            <p class="hero-subtitle">
                Kuaför Salonunuz İçin Dijital Asistanınız: Zamandan Tasarruf Edin, Müşterilerinizi Memnun Edin!
            </p>
            <div class="cta-buttons">
                <a href="#randevu" class="btn btn-primary">
                    <i class="fas fa-calendar-plus"></i>
                    Hemen Dijital Salonunu Kur
                </a>
                <a href="#hizmetler" class="btn btn-secondary">
                    <i class="fas fa-info-circle"></i>
                    Hizmetlerimizi Keşfet
                </a>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="services-section" id="hizmetler">
        <div class="container">
            <h2 class="section-title">Hizmetlerimiz</h2>
            <p class="section-subtitle">Profesyonel ekibimiz ile size en iyi hizmeti sunuyoruz</p>
            
            <div class="services-grid">
                <div class="service-card fade-in-up">
                    <div class="service-icon">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <h3 class="service-title">Randevu Sistemi</h3>
                    <p class="service-description">Salonunuzu dijitalleştirin, randevu yönetimini kolaylaştırın. Müşteri memnuniyetini artırın.</p>
                </div>
                
                <div class="service-card fade-in-up">
                    <div class="service-icon">
                        <i class="fas fa-clipboard-list"></i>
                    </div>
                    <h3 class="service-title">Hizmetler ve Fiyat Listesi</h3>
                    <p class="service-description">Salonunuzun sunduğu tüm hizmetleri ve fiyatlarını kolayca yönetin. Müşterilerinize şeffaf bir deneyim sunun.</p>
                </div>
                
                <div class="service-card fade-in-up">
                    <div class="service-icon">
                        <i class="fas fa-map-marked-alt"></i>
                    </div>
                    <h3 class="service-title">Harita ve Yol Tarifi</h3>
                    <p class="service-description">Salonunuza kolayca ulaşın. Harita ve yol tarifi ile müşterilerinizi bilgilendirin.</p>
                </div>
                
                <div class="service-card fade-in-up">
                    <div class="service-icon">
                        <i class="fas fa-share-alt"></i>
                    </div>
                    <h3 class="service-title">Sosyal Medya Entegrasyonu</h3>
                    <p class="service-description">Salonunuzun sosyal medya hesaplarını entegre edin. Müşterilerinize güncel kampanya ve duyuruları kolayca ulaştırın.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-number" data-count="5000">0</span>
                    <span class="stat-label">Mutlu Müşteri</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="15">0</span>
                    <span class="stat-label">Uzman Berber</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-count="8">0</span>
                    <span class="stat-label">Yıllık Deneyim</span>
                </div>
        <div class="stat-item">
            <span class="stat-number" data-count="24">0</span>
            <span class="stat-label">Saat Hizmet</span>
        </div>
    </div>
</div>
</section>

<BerberApp1.Components.Pages.Payment />
