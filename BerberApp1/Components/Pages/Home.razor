@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using BerberApp1.Data
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ApplicationDbContext DbContext
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<div class="portal-container">
    <!-- Hero / Search Section -->
    <section class="search-hero">
        <div class="hero-bg-overlay"></div>
        <div class="search-content">
            <h1 class="search-title">İstediğiniz Hizmeti <span class="gold-gradient">Keşfedin & Rezerv Edin</span></h1>
            <p class="search-subtitle">Güzellik salonları, klinikler, uzmanlar ve hizmet sağlayıcılar arasından size en uygun olanı bulun, anında randevu alın.</p>
            
            <div class="search-box-wrapper">
                <div class="search-input-group">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" 
                           class="search-input" 
                           placeholder="İşletme adı, adres veya hizmet arayın... (Örn: Saç Kesimi, Masaj)" 
                           value="@searchQuery"
                           @oninput="UpdateSearch" />
                </div>
            </div>
        </div>
    </section>

    <!-- Listings Section -->
    <section class="listings-section">
        <div class="container-width">
            <div class="section-title-bar">
                <h2>Tüm İşletmeler</h2>
                <span class="count-badge">@filteredSalons.Count Sonuç</span>
            </div>

            @if (filteredSalons == null || !filteredSalons.Any())
            {
                <div class="no-results-card">
                    <div class="icon-box"><i class="fas fa-search-minus"></i></div>
                    <h3>Aradığınız kriterlere uygun işletme bulunamadı</h3>
                    <p>Farklı bir arama yapmayı deneyebilir veya Bookify'a kendi işletmenizi ekleyebilirsiniz.</p>
                    <div class="action-buttons">
                        <button class="btn-clear" @onclick="ClearSearch">Aramayı Temizle</button>
                        <a href="/business" class="btn-register-cta">İşletmenizi Kaydedin</a>
                    </div>
                </div>
            }
            else
            {
                <div class="listings-grid">
                    @foreach (var salon in filteredSalons)
                    {
                        <div class="salon-card fade-in">
                            <div class="card-image-wrapper">
                                @if (!string.IsNullOrEmpty(salon.BannerUrl))
                                {
                                    <img src="@salon.BannerUrl" alt="@salon.Name" class="card-image" />
                                }
                                else if (salon.Images != null && salon.Images.Any())
                                {
                                    <img src="@salon.Images.First().ImageUrl" alt="@salon.Name" class="card-image" />
                                }
                                else
                                {
                                    <div class="card-image-placeholder">
                                        <i class="fas fa-store"></i>
                                    </div>
                                }
                                <div class="rating-badge-overlay">
                                    <i class="fas fa-star text-gold"></i>
                                    <span>4.9</span>
                                </div>
                            </div>
                            
                            <div class="card-body">
                                <h3 class="salon-name">@salon.Name</h3>
                                <div class="salon-address">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span>@salon.Address</span>
                                </div>
                                <p class="salon-desc">@(salon.Description?.Length > 100 ? salon.Description.Substring(0, 97) + "..." : salon.Description)</p>
                                
                                @if (salon.Services != null && salon.Services.Any())
                                {
                                    <div class="services-pills">
                                        @foreach (var service in salon.Services.Take(3))
                                        {
                                            <span class="service-pill">@service.Name</span>
                                        }
                                        @if (salon.Services.Count > 3)
                                        {
                                            <span class="service-pill count-pill">+@(salon.Services.Count - 3)</span>
                                        }
                                    </div>
                                }
                                
                                <div class="card-footer">
                                    <a href="@($"/salon/{salon.Id}")" class="btn-book">
                                        Randevu Al <i class="fas fa-chevron-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <!-- Footer -->
    <footer class="portal-footer">
        <div class="container-width footer-content">
            <div class="footer-info">
                <h3>Bookify</h3>
                <p>Hizmet ve randevu tabanlı tüm işletmeler için modern yönetim çözümü.</p>
            </div>
            <div class="footer-links">
                <a href="/business">İşletmeler İçin</a>
                <a href="/register">Kayıt Ol</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; @DateTime.Now.Year Bookify. Tüm Hakları Saklıdır.</p>
        </div>
    </footer>
</div>

@code {
    private List<Salon> salons = new();
    private List<Salon> filteredSalons = new();
    private string searchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            salons = await DbContext.Salons
                .AsNoTracking()
                .Include(s => s.Services)
                .Include(s => s.Images)
                .ToListAsync();
            filteredSalons = salons;
        }
        catch (Exception ex)
        {
            // Fallback empty list
            salons = new List<Salon>();
            filteredSalons = salons;
        }
    }

    private void UpdateSearch(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        FilterSalons();
    }

    private void FilterSalons()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            filteredSalons = salons;
        }
        else
        {
            filteredSalons = salons
                .Where(s => s.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
                            s.Address.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                            s.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                            s.Services.Any(ser => ser.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }
    }

    private void ClearSearch()
    {
        searchQuery = string.Empty;
        filteredSalons = salons;
    }
}
