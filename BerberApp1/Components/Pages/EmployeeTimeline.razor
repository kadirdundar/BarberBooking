@page "/employee-timeline/{SalonId:int}"
@layout Layout.DashboardLayout
@using BerberApp1.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ILogger<EmployeeTimeline> Logger
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@using QRCoder
@rendermode InteractiveServer

<div class="timeline-container-horizontal">
    <div class="timeline-header">
        <h1>Uzman Çalışma Takvimi</h1>
        <p>İşletmeniz bünyesindeki uzmanların randevu durumlarını ve çalışma planlarını görüntüleyin.</p>
    </div>
    
    <div class="header-controls">
        <div class="control-group">
            <button class="btn btn-secondary" @onclick="GenerateAndShowQrCode">
                <i class="fas fa-share-alt"></i> Paylaş
            </button>
            <button class="btn btn-primary" @onclick="NavigateToNewAppointment">
                <i class="fas fa-plus"></i> Yeni Randevu
            </button>
        </div>
    </div>

    <div class="timeline-content-wrapper">
        <div class="timeline-controls">
            <div class="employee-selector">
                <select @onchange="OnEmployeeSelected" class="form-select">
                    <option value="0">Tüm Uzmanlar</option>
                    @if (employees.Any())
                    {
                        @foreach (var employee in employees)
                        {
                            <option value="@employee.Id">@employee.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="date-scroller">
            <button class="scroll-btn" @onclick="ScrollLeft"><i class="fas fa-chevron-left"></i></button>
            <div class="date-list" @ref="dateListElement">
                @foreach (var day in datePickerDays)
                {
                    <div id="date-@day.ToString("yyyy-MM-dd")" class="date-item @GetDayClass(day)" @onclick="() => SelectDate(day)">
                        <div class="day-name-short">@day.ToString("ddd")</div>
                        <div class="day-number">@day.Day</div>
                        <div class="availability-indicator @(IsDayAvailable(day) ? "available" : "unavailable")"></div>
                    </div>
                }
            </div>
            <button class="scroll-btn" @onclick="ScrollRight"><i class="fas fa-chevron-right"></i></button>
        </div>

        <div class="service-legend">
            @foreach (var service in allServices)
            {
                <div class="legend-item">
                    <div class="legend-color-box" style="background-color: @GetServiceColor(service.Name);"></div>
                    <span>@service.Name</span>
                </div>
            }
        </div>

    <AppointmentDetailModal Appointment="selectedAppointment" IsVisible="isModalVisible" OnClose="CloseModal" />

    @if (isQrModalVisible)
    {
        <div class="qr-modal-overlay" @onclick="CloseQrModal">
            <div class="qr-modal-content" @onclick:stopPropagation="true">
                <button class="close-btn" @onclick="CloseQrModal"><i class="fas fa-times"></i></button>
                <h4>@CurrentSalon?.Name Paylaşım Merkezi</h4>
                <p>Müşterilerinizin online randevu alabilmesi için rezervasyon linkinizi paylaşın.</p>
                
                <div class="share-sections-container">
                    <!-- Bağlantı Kopyalama -->
                    <div class="share-section-block">
                        <h5>Rezervasyon Linki</h5>
                        <div class="copy-link-group">
                            <input type="text" class="copy-link-input" value="@GetSalonBookingUrl()" readonly />
                            <button class="btn btn-copy @(isCopied ? "copied" : "")" @onclick="CopyUrlToClipboard">
                                @if (isCopied)
                                {
                                    <i class="fas fa-check"></i> <span>Kopyalandı</span>
                                }
                                else
                                {
                                    <i class="fas fa-copy"></i> <span>Kopyala</span>
                                }
                            </button>
                        </div>
                    </div>

                    <!-- Hızlı Paylaşım -->
                    <div class="share-section-block">
                        <h5>Sosyal Paylaşım</h5>
                        <div class="quick-share-buttons">
                            <button class="btn-share-action btn-whatsapp" @onclick="ShareViaWhatsapp">
                                <i class="fab fa-whatsapp"></i> WhatsApp
                            </button>
                            <button class="btn-share-action btn-instagram" @onclick="ToggleInstagramInstructions">
                                <i class="fab fa-instagram"></i> Instagram
                            </button>
                        </div>
                        @if (showInstagramInstructions)
                        {
                            <div class="instagram-instructions fade-in">
                                <p><strong>Instagram'da Paylaşın:</strong></p>
                                <ol>
                                    <li>Önce yukarıdaki <strong>"Linki Kopyala"</strong> butonu ile linki kopyalayın.</li>
                                    <li>Instagram uygulamasını veya web sitesini açın.</li>
                                    <li>Profilinizden <strong>Profili Düzenle > Bağlantı Ekle</strong> bölümüne yapıştırın ya da hikayenize <strong>"Bağlantı"</strong> çıkartması olarak ekleyin.</li>
                                </ol>
                                <a href="https://instagram.com" target="_blank" class="btn-go-ig">
                                    <i class="fab fa-instagram"></i> Instagram'a Git
                                </a>
                            </div>
                        }
                    </div>

                    <!-- Karekod (QR Code) -->
                    <div class="share-section-block">
                        <h5>Karekod (QR Code)</h5>
                        <div class="qr-code-container">
                            <img src="@qrCodeBase64" alt="Randevu Karekodu" />
                        </div>
                        <a href="@qrCodeBase64" download="@($"{CurrentSalon?.Name?.Replace(" ", "-").ToLower()}-randevu-karekodu.png")" class="btn btn-sm btn-outline-light w-100">
                            <i class="fas fa-download"></i> Karekodu İndir
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (isBreakModalVisible)
    {
        <div class="qr-modal-overlay" @onclick="CloseBreakModal">
            <div class="qr-modal-content" @onclick:stopPropagation="true">
                <button class="close-btn" @onclick="CloseBreakModal"><i class="fas fa-times"></i></button>
                <h4>Mola Ekle</h4>
                <p>@selectedDate.ToShortDateString() saat @breakStartTime.ToString("HH:mm") için mola süresi seçin:</p>
                <div class="duration-buttons">
                    <button class="btn btn-outline-primary" @onclick="() => ConfirmAddBreak(15)">15 dk</button>
                    <button class="btn btn-outline-primary" @onclick="() => ConfirmAddBreak(30)">30 dk</button>
                    <button class="btn btn-outline-primary" @onclick="() => ConfirmAddBreak(45)">45 dk</button>
                    <button class="btn btn-outline-primary" @onclick="() => ConfirmAddBreak(60)">60 dk</button>
                </div>
                <div class="modal-buttons">
                    <button class="btn btn-secondary" @onclick="CloseBreakModal">İptal</button>
                </div>
            </div>
        </div>
    }

    @if (isBreakDetailModalVisible)
    {
        <div class="qr-modal-overlay" @onclick="CloseBreakDetailModal">
            <div class="qr-modal-content" @onclick:stopPropagation="true">
                <button class="close-btn" @onclick="CloseBreakDetailModal"><i class="fas fa-times"></i></button>
                <h4>Mola Detayları</h4>
                @if(selectedAppointment != null)
                {
                    <p>
                        <strong>Uzman:</strong> @employees.FirstOrDefault(e => e.Id == selectedAppointment.EmployeeId)?.Name <br/>
                        <strong>Tarih:</strong> @selectedAppointment.AppointmentDate.ToShortDateString() <br/>
                        <strong>Saat:</strong> @TimeOnly.FromTimeSpan(selectedAppointment.AppointmentTime).ToString("HH:mm") - @TimeOnly.FromTimeSpan(selectedAppointment.AppointmentTime).AddMinutes(selectedAppointment.DurationInMinutes ?? 0).ToString("HH:mm")
                    </p>
                }
                <div class="modal-buttons">
                    <button class="btn btn-danger" @onclick="() => DeleteBreak(selectedAppointment.Id)">
                        <i class="fas fa-trash"></i> Molayı Sil
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseBreakDetailModal">Kapat</button>
                </div>
            </div>
        </div>
    }

    <div class="timeline-wrapper-horizontal">
        <div class="employee-list">
            <div class="employee-info-header"></div>
            @foreach (var employee in GetFilteredEmployees())
            {
                <div class="employee-info-horizontal">
                    <img src="@(string.IsNullOrEmpty(employee.PictureUrl) ? "images/barber.png" : employee.PictureUrl)" alt="@employee.Name" />
                    <span>@employee.Name</span>
                </div>
            }
        </div>

        <div class="timeline-grid-container">
            <div class="timeline-hours-horizontal">
                @if (openingTime.HasValue && closingTime.HasValue)
                {
                    @for (int hour = openingTime.Value.Hour; hour < closingTime.Value.Hour; hour++)
                    {
                        <div class="hour-label-horizontal" style="min-width: 120px;">@hour:00</div>
                    }
                }
            </div>
            <div class="timeline-tracks">
                @foreach (var employee in GetFilteredEmployees())
                {
                    <div class="appointments-track-horizontal" @onclick="(e) => HandleTimelineClick(e, employee.Id)">
                        @foreach (var appointment in GetAppointmentsForEmployee(employee.Id))
                        {
                            var totalDuration = appointment.IsBreak ? (appointment.DurationInMinutes ?? 0) : appointment.AppointmentServices.Sum(s => s.Service?.DurationInMinutes ?? 0);
                            var appointmentTitle = appointment.IsBreak ? "Mola" : $"{appointment.CustomerName} - {string.Join(", ", appointment.AppointmentServices.Select(s => s.Service?.Name))}";

                            <div class="appointment-block-horizontal @(appointment.IsBreak ? "break-block" : "")" style="@GetAppointmentStyle(appointment, totalDuration)" title="@appointmentTitle" @onclick="() => ShowAppointmentDetails(appointment)" @onclick:stopPropagation="true">
                                @if(appointment.IsBreak)
                                {
                                    <i class="fas fa-coffee break-icon"></i>
                                }
                                else
                                {
                                    <div class="service-bars">
                                        @foreach(var service in appointment.AppointmentServices)
                                        {
                                            var servicePercentage = (double)(service.Service?.DurationInMinutes ?? 0) / totalDuration * 100;
                                            <div class="service-bar" style="background-color: @GetServiceColor(service.Service?.Name ?? string.Empty); width: @(servicePercentage.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;"></div>
                                        }
                                    </div>
                                    <span class="customer-initials">@GetInitials(appointment.CustomerName)</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
</div>

@code {
    [Parameter]
    public int SalonId { get; set; }

    private string qrCodeBase64 = "";
    private bool isQrModalVisible = false;
    private Employee? selectedEmployeeForQr;
    private bool isCopied = false;
    private bool showInstagramInstructions = false;

    private List<Employee> employees = new();
    private List<Appointment> appointments = new();
    private List<Service> allServices = new();
    private int selectedEmployeeId = 0;
    private DateTime selectedDate = DateTime.Today;
    private Salon? CurrentSalon;
    private TimeOnly? openingTime;
    private TimeOnly? closingTime;
    private Appointment? selectedAppointment;
    private bool isModalVisible = false;
    private bool isBreakDetailModalVisible = false;
    private bool isBreakModalVisible = false;
    private TimeOnly breakStartTime;
    private int breakEmployeeId;
    private List<DateTime> datePickerDays = new List<DateTime>();
    private ElementReference dateListElement;
    private Dictionary<DateTime, bool> dayAvailability = new Dictionary<DateTime, bool>();

    protected override async Task OnInitializedAsync()
    {
        GenerateDatePickerDays();
        await LoadDataAsync();
        await CheckDaysAvailability();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("bookingInterop.enableDragScroll", dateListElement);
            await JSRuntime.InvokeVoidAsync("bookingInterop.scrollToElement", dateListElement, $"date-{selectedDate.ToString("yyyy-MM-dd")}");
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            CurrentSalon = await DbContext.Salons
                .AsNoTracking()
                .Include(s => s.WorkingHours)
                .FirstOrDefaultAsync(s => s.Id == SalonId);

            if (CurrentSalon != null)
            {
                var workingHours = CurrentSalon.WorkingHours.FirstOrDefault(wh => wh.DayOfWeek == selectedDate.DayOfWeek);
                openingTime = workingHours?.IsClosed == false ? workingHours.OpeningTime : null;
                closingTime = workingHours?.IsClosed == false ? workingHours.ClosingTime : null;
            }

            employees = await DbContext.Employees
                .AsNoTracking()
                .Where(e => e.SalonId == SalonId)
                .ToListAsync();

            allServices = await DbContext.Services
                .AsNoTracking()
                .Where(s => s.SalonId == SalonId)
                .ToListAsync();

            appointments = await DbContext.Appointments
                .AsNoTracking()
                .Include(a => a.AppointmentServices)
                .ThenInclude(aps => aps.Service)
                .Where(a => a.SalonId == SalonId && a.AppointmentDate.Date == selectedDate.Date)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading timeline data for Salon ID {SalonId} on date {Date}", SalonId, selectedDate);
        }
        await InvokeAsync(StateHasChanged);
    }

    private void GenerateDatePickerDays()
    {
        datePickerDays.Clear();
        for (int i = -15; i < 15; i++)
        {
            datePickerDays.Add(DateTime.Today.AddDays(i));
        }
    }
    
    private async Task SelectDate(DateTime date)
    {
        selectedDate = date;
        await LoadDataAsync();
    }

    private async Task OnEmployeeSelected(ChangeEventArgs e)
    {
        selectedEmployeeId = int.Parse(e.Value?.ToString() ?? "0");
        await LoadDataAsync();
    }

    private void GenerateAndShowQrCode()
    {
        var salonBookingUrl = GetSalonBookingUrl();
 
        using (QRCodeGenerator qrGenerator = new QRCodeGenerator())
        {
            QRCodeData qrCodeData = qrGenerator.CreateQrCode(salonBookingUrl, QRCodeGenerator.ECCLevel.Q);
            using (PngByteQRCode qrCode = new PngByteQRCode(qrCodeData))
            {
                byte[] qrCodeImage = qrCode.GetGraphic(20);
                qrCodeBase64 = "data:image/png;base64," + Convert.ToBase64String(qrCodeImage);
            }
        }
        isQrModalVisible = true;
    }

    private void CloseQrModal()
    {
        isQrModalVisible = false;
        qrCodeBase64 = "";
        selectedEmployeeForQr = null;
        isCopied = false;
        showInstagramInstructions = false;
    }

    private string GetSalonBookingUrl()
    {
        var uri = new Uri(Navigation.BaseUri);
        return string.IsNullOrEmpty(CurrentSalon?.NickName)
            ? $"{uri.Scheme}://{uri.Authority}/salon/{SalonId}"
            : $"{uri.Scheme}://{uri.Authority}/{CurrentSalon.NickName}";
    }

    private async Task CopyUrlToClipboard()
    {
        var url = GetSalonBookingUrl();
        var success = await JSRuntime.InvokeAsync<bool>("bookingInterop.copyToClipboard", url);
        if (success)
        {
            isCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            isCopied = false;
            StateHasChanged();
        }
    }

    private void ShareViaWhatsapp()
    {
        var url = GetSalonBookingUrl();
        var text = $"Merhaba! {CurrentSalon?.Name} salonumuzdan hızlıca randevu almak için bu bağlantıyı kullanabilirsiniz: {url}";
        var shareUrl = $"https://api.whatsapp.com/send?text={Uri.EscapeDataString(text)}";
        Navigation.NavigateTo(shareUrl, forceLoad: true);
    }

    private void ToggleInstagramInstructions()
    {
        showInstagramInstructions = !showInstagramInstructions;
    }

    private void NavigateToNewAppointment()
    {
        // Always navigate to the main booking page for the salon, letting the user choose the employee.
        if (CurrentSalon != null && !string.IsNullOrEmpty(CurrentSalon.NickName))
        {
            Navigation.NavigateTo($"/{CurrentSalon.NickName}");
        }
        else
        {
            Navigation.NavigateTo($"/salon/{SalonId}");
        }
    }




    private List<Employee> GetFilteredEmployees()
    {
        if (selectedEmployeeId == 0)
        {
            return employees;
        }
        return employees.Where(e => e.Id == selectedEmployeeId).ToList();
    }

    private List<Appointment> GetAppointmentsForEmployee(int employeeId)
    {
        return appointments.Where(a => a.EmployeeId == employeeId).ToList();
    }

    private string GetDayClass(DateTime day)
    {
        string cssClass = "date-item";
        if (day.Date == DateTime.Today) cssClass += " today";
        if (day.Date == selectedDate.Date) cssClass += " selected";
        return cssClass;
    }

    private async Task CheckDaysAvailability()
    {
        dayAvailability.Clear();
        foreach (var day in datePickerDays)
        {
            dayAvailability[day.Date] = await IsDayActuallyAvailable(day);
        }
    }

    private async Task<bool> IsDayActuallyAvailable(DateTime date)
    {
        if (CurrentSalon == null)
        {
            CurrentSalon = await DbContext.Salons.AsNoTracking().Include(s => s.WorkingHours).FirstOrDefaultAsync(s => s.Id == SalonId);
            if (CurrentSalon == null) return false;
        }

        var workingHours = CurrentSalon.WorkingHours.FirstOrDefault(wh => wh.DayOfWeek == date.DayOfWeek);
        return workingHours != null && !workingHours.IsClosed;
    }

    private bool IsDayAvailable(DateTime day)
    {
        return dayAvailability.TryGetValue(day.Date, out bool isAvailable) && isAvailable;
    }

    private string GetAppointmentStyle(Appointment appointment, int totalDuration)
    {
        if (!openingTime.HasValue) return "";

        var startMinute = (appointment.AppointmentTime.Hours - openingTime.Value.Hour) * 60 + appointment.AppointmentTime.Minutes;
        
        var left = (double)startMinute / 60 * 120;
        var width = (double)totalDuration / 60 * 120;

        return $"left: {left.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}px; width: {width.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}px;";
    }

    private string GetServiceColor(string serviceName)
    {
        if (string.IsNullOrEmpty(serviceName)) return "#e0e0e0";
        
        var hash = serviceName.GetHashCode();
        var r = (hash & 0xFF0000) >> 16;
        var g = (hash & 0x00FF00) >> 8;
        var b = hash & 0x0000FF;
        
        return $"#{r:X2}{g:X2}{b:X2}";
    }
    
        private async Task HandleTimelineClick(MouseEventArgs e, int employeeId)
        {
            if (openingTime == null) return;
            
            // Calculate the clicked time on the timeline
            var hourWidth = 120; // Must match CSS
            var clickX = e.OffsetX;
            var clickedMinutes = (clickX / hourWidth) * 60;
            var clickedTime = openingTime.Value.AddMinutes(clickedMinutes);
            
            // Round to nearest 15 minutes
            var totalMinutes = clickedTime.Hour * 60 + clickedTime.Minute;
            var roundedMinutes = (int)Math.Round(totalMinutes / 15.0) * 15;
            
            breakStartTime = new TimeOnly(roundedMinutes / 60, roundedMinutes % 60);
            breakEmployeeId = employeeId;
            isBreakModalVisible = true;
        }
    
    
        private void CloseBreakModal()
        {
            isBreakModalVisible = false;
        }

    private async Task ConfirmAddBreak(int duration)
    {
        if (CurrentSalon == null || breakEmployeeId == 0) return;

        var newBreak = new Appointment
        {
            SalonId = SalonId,
            EmployeeId = breakEmployeeId,
            AppointmentDate = selectedDate.Date,
            AppointmentTime = breakStartTime.ToTimeSpan(),
            CustomerName = "Mola",
            IsBreak = true,
            DurationInMinutes = duration
        };

        DbContext.Appointments.Add(newBreak);
        await DbContext.SaveChangesAsync();
        
        isBreakModalVisible = false;
        await LoadDataAsync(); // Refresh timeline
    }

    private string GetInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "";
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 1)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        }
        return $"{parts[0][0]}".ToUpper();
    }

    private void ShowAppointmentDetails(Appointment appointment)
    {
        selectedAppointment = appointment;
        if (appointment.IsBreak)
        {
            isBreakDetailModalVisible = true;
        }
        else
        {
            isModalVisible = true;
        }
    }

    private void CloseBreakDetailModal()
    {
        isBreakDetailModalVisible = false;
        selectedAppointment = null;
    }

    private async Task DeleteBreak(int appointmentId)
    {
        try
        {
            var appointmentToDelete = await DbContext.Appointments.FindAsync(appointmentId);
            if (appointmentToDelete != null && appointmentToDelete.IsBreak)
            {
                DbContext.Appointments.Remove(appointmentToDelete);
                await DbContext.SaveChangesAsync();
                await LoadDataAsync(); // Refresh the timeline
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting break with ID {AppointmentId}", appointmentId);
        }
        finally
        {
            CloseBreakDetailModal();
        }
    }

    private async Task ScrollLeft()
    {
        await JSRuntime.InvokeVoidAsync("bookingInterop.scroll", dateListElement, "left");
    }

    private async Task ScrollRight()
    {
        await JSRuntime.InvokeVoidAsync("bookingInterop.scroll", dateListElement, "right");
    }

    private void CloseModal()
    {
        isModalVisible = false;
        selectedAppointment = null;
    }
}