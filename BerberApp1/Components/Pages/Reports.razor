@page "/reports/{SalonId:int}"
@using BerberApp1.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ILogger<Reports> Logger

<div class="reports-container fade-in">
    <div class="reports-header">
        <div class="header-content">
            <h1>Raporlar & İstatistikler</h1>
            <p>İşletmenizin performansını detaylı olarak inceleyin.</p>
        </div>
        <div class="header-date">
            <span class="date-badge"><i class="far fa-calendar-alt"></i> @DateTime.Today.ToString("dd MMMM yyyy")</span>
        </div>
    </div>

    <div class="stats-grid">
        <!-- Daily Revenue -->
        <div class="stat-card gold-glow">
            <div class="stat-icon-wrapper">
                <i class="fas fa-coins"></i>
            </div>
            <div class="stat-info">
                <h3>Bugünkü Ciro</h3>
                <p class="stat-value">@dailyRevenue.ToString("C0")</p>
                <span class="stat-trend positive">
                    <i class="fas fa-arrow-up"></i> Günlük
                </span>
            </div>
        </div>

        <!-- Weekly Revenue -->
        <div class="stat-card">
            <div class="stat-icon-wrapper blue-icon">
                <i class="fas fa-wallet"></i>
            </div>
            <div class="stat-info">
                <h3>Bu Haftaki Ciro</h3>
                <p class="stat-value">@weeklyRevenue.ToString("C0")</p>
                <span class="stat-label">Pazartesi'den itibaren</span>
            </div>
        </div>

        <!-- Monthly Revenue -->
        <div class="stat-card">
            <div class="stat-icon-wrapper green-icon">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="stat-info">
                <h3>Bu Ayki Ciro</h3>
                <p class="stat-value">@monthlyRevenue.ToString("C0")</p>
                <span class="stat-label">Bu ay toplam</span>
            </div>
        </div>

        <!-- Daily Appointments -->
        <div class="stat-card">
            <div class="stat-icon-wrapper purple-icon">
                <i class="fas fa-calendar-check"></i>
            </div>
            <div class="stat-info">
                <h3>Bugünkü Randevu</h3>
                <p class="stat-value">@dailyAppointments</p>
                <span class="stat-label">Adet randevu</span>
            </div>
        </div>
    </div>

    <div class="charts-section">
        <div class="chart-card">
            <div class="card-header">
                <h4><i class="fas fa-crown"></i> En Popüler Hizmetler</h4>
            </div>
            <div class="card-body">
                @if (topServices.Any())
                {
                    <div class="bar-chart-container">
                        @foreach (var service in topServices)
                        {
                            // Calculate percentage for bar width (max value assumption needed or relative to total)
                            // For simplicity, let's take the max value in the set to scale bars
                            var maxCount = topServices.Values.Max();
                            var widthPercentage = (double)service.Value / maxCount * 100;
                            
                            <div class="bar-row">
                                <div class="bar-label">@service.Key</div>
                                <div class="bar-track">
                                    <div class="bar-fill" style="width: @widthPercentage%;"></div>
                                </div>
                                <div class="bar-value">@service.Value</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-chart-bar"></i>
                        <p>Henüz yeterli veri yok.</p>
                    </div>
                }
            </div>
        </div>

        <div class="chart-card">
           <div class="card-header">
                <h4><i class="fas fa-lightbulb"></i> İpuçları</h4>
            </div>
            <div class="card-body tips-body">
                <div class="tip-item">
                    <i class="fas fa-star"></i>
                    <p>Müşteri memnuniyetini artırmak için randevulardan sonra geri bildirim isteyin.</p>
                </div>
                <div class="tip-item">
                    <i class="fas fa-clock"></i>
                    <p>Yoğun saatlerde ek personel planlaması yaparak bekleme sürelerini azaltabilirsiniz.</p>
                </div>
                 <div class="tip-item">
                    <i class="fas fa-bullhorn"></i>
                    <p>Düşük yoğunluklu günlerde özel kampanyalar düzenleyerek doluluk oranını artırın.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int SalonId { get; set; }

    private decimal dailyRevenue;
    private decimal weeklyRevenue;
    private decimal monthlyRevenue;
    private int dailyAppointments;
    private Dictionary<string, int> topServices = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var today = DateTime.Today;
            var startOfWeek = today.AddDays(-(int)today.DayOfWeek + (int)DayOfWeek.Monday);
            var startOfMonth = new DateTime(today.Year, today.Month, 1);

            var allAppointments = await DbContext.Appointments
                .AsNoTracking()
                .Include(a => a.AppointmentServices)
                .ThenInclude(aps => aps.Service)
                .Where(a => a.SalonId == SalonId && !a.IsBreak)
                .ToListAsync();

            dailyRevenue = allAppointments
                .Where(a => a.AppointmentDate.Date == today)
                .SelectMany(a => a.AppointmentServices)
                .Sum(aps => aps.Service?.Price ?? 0);

            weeklyRevenue = allAppointments
                .Where(a => a.AppointmentDate.Date >= startOfWeek)
                .SelectMany(a => a.AppointmentServices)
                .Sum(aps => aps.Service?.Price ?? 0);

            monthlyRevenue = allAppointments
                .Where(a => a.AppointmentDate.Date >= startOfMonth)
                .SelectMany(a => a.AppointmentServices)
                .Sum(aps => aps.Service?.Price ?? 0);

            dailyAppointments = allAppointments
                .Count(a => a.AppointmentDate.Date == today);

            topServices = allAppointments
                .SelectMany(a => a.AppointmentServices)
                .Where(aps => aps.Service != null)
                .GroupBy(aps => aps.Service!.Name)
                .OrderByDescending(g => g.Count())
                .Take(5)
                .ToDictionary(g => g.Key, g => g.Count());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading report data for SalonId {SalonId}", SalonId);
        }
    }
}