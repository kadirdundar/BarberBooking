@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject NavigationManager NavigationManager

<PageTitle>Bookify - Giriş Yap</PageTitle>

<div class="login-container">
    <div class="login-glow"></div>
    <div class="login-card">
        <div class="login-header">
            <div class="logo-icon-wrapper">
                <i class="fas fa-scissors logo-icon"></i>
            </div>
            <h2 class="text-gradient">Hoş Geldiniz</h2>
            <p>Devam etmek için giriş yapın</p>
        </div>
        <div class="login-body">
            <a href="api/auth/login?returnUrl=@(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl)" class="google-signin-btn">
                <i class="fab fa-google btn-icon"></i>
                <span>Google ile Giriş Yap</span>
            </a>
        </div>
        <div class="login-footer">
            <p>&copy; @DateTime.Now.Year Bookify. Tüm hakları saklıdır.</p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }
}