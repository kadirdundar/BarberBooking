@page "/booking-confirmation"
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<div class="confirmation-container">
    <div class="confirmation-card fade-in">
        <div class="confirmation-icon pulse-animation">
            <i class="fas fa-check-circle"></i>
        </div>
        <h1>Randevunuz Onaylandı!</h1>
        <p class="confirmation-message">Randevu bilgileriniz başarıyla sisteme kaydedilmiştir. <br/> Sizi ağırlamaktan mutluluk duyacağız.</p>
        
        <div class="action-buttons">
            <button class="btn btn-primary" @onclick="GoToHome">Ana Sayfaya Dön</button>
             <button class="btn btn-outline-secondary" onclick="window.print()">
                <i class="fas fa-print"></i> Yazdır
            </button>
        </div>
    </div>
</div>

@code {
    private void GoToHome()
    {
        NavigationManager.NavigateTo("/");
    }
}