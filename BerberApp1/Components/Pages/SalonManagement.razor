@page "/salon-management/{SalonId:int}"
@layout Layout.DashboardLayout
@using BerberApp1.Data
@using Microsoft.EntityFrameworkCore
@using BerberApp1.Services
@inject ApplicationDbContext DbContext
@inject ILogger<SalonManagement> Logger
@inject IWebHostEnvironment Environment
@inject IJSRuntime JSRuntime
@inject IFileStorageService FileStorageService

<div class="salon-management-container fade-in">
    @if (salon == null)
    {
        <div class="loading-state">
            <div class="spinner-container">
                <div class="luxury-spinner"></div>
            </div>
            <p>İşletme bilgileri yükleniyor...</p>
        </div>
    }
    else
    {
        <div class="management-header">
            <div class="header-text">
                <h1>@salon.Name</h1>
                <p>İşletme Yönetim Paneli</p>
            </div>
        </div>

        <div class="management-body">
            <!-- Sidebar Navigation -->
            <div class="management-sidebar">
                <button class="nav-btn @(activeTab == "services" ? "active" : "")" @onclick='() => SetActiveTab("services")'>
                    <i class="fas fa-cut"></i> Hizmetler
                </button>
                <button class="nav-btn @(activeTab == "employees" ? "active" : "")" @onclick='() => SetActiveTab("employees")'>
                    <i class="fas fa-users"></i> Uzmanlar
                </button>
                <button class="nav-btn @(activeTab == "hours" ? "active" : "")" @onclick='() => SetActiveTab("hours")'>
                    <i class="fas fa-clock"></i> Çalışma Saatleri
                </button>
                <button class="nav-btn @(activeTab == "settings" ? "active" : "")" @onclick='() => SetActiveTab("settings")'>
                    <i class="fas fa-cogs"></i> Genel Ayarlar
                </button>
            </div>

            <!-- Content Area -->
            <div class="management-content">
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="status-alert @(isSuccess ? "alert-success" : "alert-danger")">
                        <i class="@(isSuccess ? "fas fa-check-circle" : "fas fa-exclamation-circle")"></i> @statusMessage
                    </div>
                }

                @switch (activeTab)
                {
                    case "services":
                        <div class="content-section fade-in">
                            <div class="section-header">
                                <h3>Hizmet Yönetimi</h3>
                                <p>Müşterilerinize sunduğunuz hizmetleri buradan yönetin.</p>
                            </div>

                            <div class="add-card">
                                <h5><i class="fas fa-plus-circle"></i> Yeni Hizmet Ekle</h5>
                                <EditForm Model="@newService" OnValidSubmit="AddService" class="form-row">
                                    <DataAnnotationsValidator />
                                    <div class="form-group col-md-5">
                                        <InputText @bind-Value="newService.Name" class="form-control" placeholder="Hizmet Adı (Örn: Saç Kesimi)" />
                                    </div>
                                    <div class="form-group col-md-3">
                                        <div class="input-group">
                                            <span class="input-group-text">₺</span>
                                            <InputNumber @bind-Value="newService.Price" class="form-control" placeholder="Fiyat" />
                                        </div>
                                    </div>
                                    <div class="form-group col-md-2">
                                        <div class="input-group">
                                            <InputNumber @bind-Value="newService.DurationInMinutes" class="form-control" placeholder="Süre" />
                                            <span class="input-group-text">dk</span>
                                        </div>
                                    </div>
                                    <div class="form-group col-md-2">
                                        <button type="submit" class="btn btn-primary w-100">Ekle</button>
                                    </div>
                                </EditForm>
                                <small class="text-muted d-block mt-2"><i class="fas fa-info-circle"></i> Mola için "Mola", Fiyat: 0, Süre: 30 olarak ekleyin.</small>
                            </div>

                            <div class="services-list">
                                @if (salon.Services.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table management-table">
                                            <thead>
                                                <tr>
                                                    <th>Hizmet Adı</th>
                                                    <th>Fiyat</th>
                                                    <th>Süre (dk)</th>
                                                    <th class="text-end">İşlemler</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var service in salon.Services)
                                                {
                                                    <tr>
                                                        <td><InputText @bind-Value="service.Name" class="form-control form-control-sm" /></td>
                                                        <td>
                                                            <div class="input-group input-group-sm">
                                                                <span class="input-group-text">₺</span>
                                                                <InputNumber @bind-Value="service.Price" class="form-control" />
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="input-group input-group-sm">
                                                                <InputNumber @bind-Value="service.DurationInMinutes" class="form-control" />
                                                                <span class="input-group-text">dk</span>
                                                            </div>
                                                        </td>
                                                        <td class="text-end">
                                                            <div class="btn-group">
                                                                <button class="btn btn-sm btn-icon btn-save" title="Kaydet" @onclick="() => UpdateService(service)"><i class="fas fa-save"></i></button>
                                                                <button class="btn btn-sm btn-icon btn-delete" title="Sil" @onclick="() => DeleteService(service.Id)"><i class="fas fa-trash"></i></button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="empty-state">
                                        <p>Henüz hizmet eklenmemiş.</p>
                                    </div>
                                }
                            </div>
                        </div>
                        break;

                    case "employees":
                        <div class="content-section fade-in">
                            <div class="section-header">
                                <h3>Uzman Kadrosu</h3>
                                <p>İşletmenizdeki uzmanları yönetin.</p>
                            </div>

                            <div class="add-card">
                                <h5><i class="fas fa-user-plus"></i> Yeni Uzman Ekle</h5>
                                <EditForm Model="@newEmployee" OnValidSubmit="AddEmployee" class="form-row">
                                    <DataAnnotationsValidator />
                                    <div class="form-group col-md-5">
                                        <InputText @bind-Value="newEmployee.Name" class="form-control" placeholder="Ad Soyad" />
                                    </div>
                                    <div class="form-group col-md-5">
                                        <div class="custom-file-upload">
                                            <InputFile OnChange="@OnEmployeeImageSelected" class="form-control" accept="image/*" />
                                            @if (!string.IsNullOrEmpty(newEmployee.PictureUrl))
                                            {
                                                <div class="mt-2">
                                                    <span class="text-success small"><i class="fas fa-check"></i> Görsel seçildi</span>
                                                    <img src="@newEmployee.PictureUrl" alt="Preview" style="height: 30px; width: 30px; border-radius: 50%; object-fit: cover; margin-left: 5px;" />
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="form-group col-md-2">
                                        <button type="submit" class="btn btn-primary w-100">Ekle</button>
                                    </div>
                                </EditForm>
                            </div>

                            <div class="employees-grid">
                                @foreach (var employee in salon.Employees)
                                {
                                    <div class="employee-manage-card">
                                        <div class="card-img">
                                            <img src="@(string.IsNullOrEmpty(employee.PictureUrl) ? "images/barber.png" : employee.PictureUrl)" alt="@employee.Name" />
                                        </div>
                                        <div class="card-info">
                                            <h5>@employee.Name</h5>
                                            <p class="role">Uzman</p>
                                        </div>
                                        <div class="card-actions">
                                            <button class="btn btn-sm btn-outline-danger w-100" @onclick="() => DeleteEmployee(employee.Id)">
                                                <i class="fas fa-trash"></i> Sil
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        break;

                    case "hours":
                        <div class="content-section fade-in">
                             <div class="section-header">
                                <h3>Çalışma Saatleri</h3>
                                <p>İşletmenizin açık olduğu gün ve saatleri belirleyin.</p>
                            </div>
                            
                            <div class="hours-grid">
                                @foreach (var wh in workingHours)
                                {
                                    <div class="hour-card @(wh.IsClosed ? "closed" : "")">
                                        <div class="day-label">@wh.DayOfWeek</div>
                                        
                                        <div class="status-toggle">
                                            <label class="switch">
                                                <input type="checkbox" checked="@(!wh.IsClosed)" @onchange="@(e => { wh.IsClosed = !(bool)e.Value!; })" />
                                                <span class="slider"></span>
                                            </label>
                                            <span class="status-text">@(wh.IsClosed ? "Kapalı" : "Açık")</span>
                                        </div>

                                        <div class="time-range @(wh.IsClosed ? "hidden" : "")">
                                             <div class="time-input-group">
                                                <input type="time" @bind="wh.OpeningTime" class="form-control" />
                                                <span>-</span>
                                                <input type="time" @bind="wh.ClosingTime" class="form-control" />
                                             </div>
                                        </div>
                                        
                                        <button class="btn btn-sm btn-primary mt-2 w-100" @onclick="() => UpdateWorkingHour(wh)">
                                            <i class="fas fa-save"></i> Güncelle
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                        break;

                    case "settings":
                        <div class="content-section fade-in">
                            <div class="section-header">
                                <h3>Genel Ayarlar</h3>
                                <p>İşletme bilgilerini ve görsellerini düzenleyin.</p>
                            </div>

                            <div class="settings-form-wrapper">
                                <EditForm Model="@salon" OnValidSubmit="UpdateSalonSettings">
                                    <DataAnnotationsValidator />
                                    <div class="form-group mb-3">
                                        <label>İşletme Adı</label>
                                        <InputText @bind-Value="salon.Name" class="form-control" disabled />
                                        <small class="text-muted">İşletme adı değiştirilemez.</small>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label>Adres</label>
                                        <InputTextArea @bind-Value="salon.Address" class="form-control" rows="3" />
                                    </div>

                                    <h4 class="mt-4 mb-3">Sosyal Medya Hesapları</h4>
                                    <div class="row">
                                        <div class="form-group col-md-6 mb-3">
                                            <label><i class="fab fa-instagram text-danger me-1"></i> Instagram</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-dark border-secondary text-light">instagram.com/</span>
                                                <InputText @bind-Value="salon.InstagramUrl" class="form-control" placeholder="kullanici_adi" />
                                            </div>
                                        </div>
                                        <div class="form-group col-md-6 mb-3">
                                            <label><i class="fab fa-tiktok text-light me-1"></i> TikTok</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-dark border-secondary text-light">tiktok.com/@@</span>
                                                <InputText @bind-Value="salon.TiktokUrl" class="form-control" placeholder="kullanici_adi" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="form-group col-md-6 mb-3">
                                            <label><i class="fab fa-twitter text-info me-1"></i> Twitter / X</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-dark border-secondary text-light">x.com/</span>
                                                <InputText @bind-Value="salon.TwitterUrl" class="form-control" placeholder="kullanici_adi" />
                                            </div>
                                        </div>
                                        <div class="form-group col-md-6 mb-3">
                                            <label><i class="fab fa-whatsapp text-success me-1"></i> WhatsApp</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-dark border-secondary text-light">wa.me/</span>
                                                <InputText @bind-Value="salon.WhatsappNumber" class="form-control" placeholder="905XXXXXXXXX" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group mb-4">
                                        <label><i class="fas fa-globe text-primary me-1"></i> Web Sitesi</label>
                                        <InputText @bind-Value="salon.WebsiteUrl" class="form-control" placeholder="https://www.websiteniz.com" />
                                    </div>

                                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Değişiklikleri Kaydet</button>
                                </EditForm>
                            </div>
                            
                            <hr class="divider my-5" style="border-top: 1px solid rgba(255,255,255,0.15);" />
                            
                            <div class="gallery-upload-section">
                                <h4>Profil Fotoğrafı</h4>
                                <p class="text-muted">İşletmenizin profil resmi (Örn: Logo veya Erkek Berber görseli).</p>
                                
                                @if (!string.IsNullOrEmpty(salon.LogoUrl))
                                {
                                    <div class="current-logo mb-3 d-flex align-items-center gap-3">
                                        <img src="@salon.LogoUrl" alt="Logo" style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%; border: 2px solid var(--primary-gold);" />
                                        <button class="btn btn-sm btn-outline-danger" @onclick="RemoveLogo"><i class="fas fa-trash"></i> Profil Fotoğrafını Kaldır</button>
                                    </div>
                                }

                                <div class="mb-4">
                                    <InputFile OnChange="@OnLogoFileSelected" class="form-control" accept="image/*" />
                                </div>

                                <hr class="divider my-4" />

                                <h4>Banner Görseli</h4>
                                <p class="text-muted">İşletme kapak fotoğrafı.</p>
                                
                                @if (!string.IsNullOrEmpty(salon.BannerUrl))
                                {
                                    <div class="current-banner mb-3">
                                        <img src="@salon.BannerUrl" alt="Banner" style="width: 100%; max-height: 200px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);" />
                                        <button class="btn btn-sm btn-outline-danger mt-2" @onclick="RemoveBanner"><i class="fas fa-trash"></i> Bannerı Kaldır</button>
                                    </div>
                                }

                                <div class="mb-4">
                                    <InputFile OnChange="@OnBannerFileSelected" class="form-control" accept="image/*" />
                                </div>

                                <hr class="divider my-4" />

                                <h4>Arka Plan Görseli</h4>
                                <p class="text-muted">Mobil Linktree sayfasının arka plan resmi.</p>
                                
                                @if (!string.IsNullOrEmpty(salon.BackgroundUrl))
                                {
                                    <div class="current-banner mb-3">
                                        <img src="@salon.BackgroundUrl" alt="Arka Plan" style="width: 100%; max-height: 200px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);" />
                                        <button class="btn btn-sm btn-outline-danger mt-2" @onclick="RemoveBackground"><i class="fas fa-trash"></i> Arka Planı Kaldır</button>
                                    </div>
                                }

                                <div class="mb-4">
                                    <InputFile OnChange="@OnBackgroundFileSelected" class="form-control" accept="image/*" />
                                </div>

                                <hr class="divider my-4" />

                                <h4>Galeri Yönetimi</h4>
                                <div class="mb-4">
                                    <InputFile OnChange="@OnImageFileSelected" class="form-control" accept="image/*" />
                                </div>
                                
                                <div class="gallery-grid mt-3">
                                    @foreach (var image in salon.Images)
                                    {
                                        <div class="gallery-item">
                                            <img src="@image.ImageUrl" alt="Salon" />
                                            <button class="delete-img-btn" @onclick="() => DeleteSalonImage(image.Id)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        break;
                }
            </div>
        </div>

        @if (isCropModalVisible)
        {
            <div class="crop-modal-overlay">
                <div class="crop-modal-content" @onclick:stopPropagation="true">
                    <h4>Görseli Ayarla</h4>
                    <p>Görselin görünmesini istediğiniz alanını seçin ve ayarlayın.</p>
                    
                    <div class="crop-container" style="position: relative;">
                        <img id="cropper-target-image" src="@cropImageSourceUrl" alt="Kırpılacak Görsel" style="max-width: 100%; max-height: 350px; display: block;" />
                        
                        @if (isCroppingInProgress)
                        {
                            <div class="crop-loading-overlay">
                                <div class="spinner-border text-gold" role="status"></div>
                                <p class="mt-2 text-white font-weight-bold" style="font-size: 0.9rem;">Görsel Kırpılıyor...</p>
                            </div>
                        }
                    </div>
                    
                    <div class="crop-actions">
                        @if (isCroppingInProgress)
                        {
                            <button type="button" class="btn btn-primary" disabled>
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                İşleniyor...
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary" @onclick="CancelCrop">İptal</button>
                            <button type="button" class="btn btn-primary" @onclick="ConfirmCrop">Kırp ve Kaydet</button>
                        }
                    </div>
                </div>
            </div>
        }

        @if (isProcessing)
        {
            <div class="global-loading-overlay">
                <div class="loading-card">
                    <div class="spinner-container">
                        <div class="luxury-spinner"></div>
                    </div>
                    <h5>@processingMessage</h5>
                    <p>Lütfen bu işlem tamamlanana kadar bekleyin.</p>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int SalonId { get; set; }
    private Salon? salon;
    private Service newService = new();
    private Employee newEmployee = new();
    private List<WorkingHoursViewModel> workingHours = new();
    private string? statusMessage;
    private bool isSuccess;
    private string activeTab = "services";

    // Global Processing State
    private bool isProcessing = false;
    private string processingMessage = "İşlem yapılıyor...";

    // Crop Modal States
    private bool isCropModalVisible = false;
    private string cropImageSourceUrl = "";
    private double? cropAspectRatio = 1.0;
    private string cropTarget = "employee"; // "employee", "logo", "banner", "background", "gallery"
    private bool isCropInitializing = false;
    private bool isCroppingInProgress = false;

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
        statusMessage = null;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSalon();
        if (salon != null)
        {
            InitializeWorkingHours();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (isCropInitializing && isCropModalVisible)
        {
            isCropInitializing = false;
            await JSRuntime.InvokeVoidAsync("bookingInterop.initCropper", "cropper-target-image", cropAspectRatio);
        }
    }
    
    private async Task LoadSalon()
    {
        try
        {
            salon = await DbContext.Salons
                                 .AsNoTracking()
                                 .Include(s => s.Services.OrderBy(sv => sv.Name))
                                 .Include(s => s.WorkingHours)
                                 .Include(s => s.Employees.OrderBy(e => e.Name))
                                 .Include(s => s.Images)
                                 .FirstOrDefaultAsync(s => s.Id == SalonId);
       }
       catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading salon details for SalonId {SalonId}", SalonId);
            await ShowStatusMessage("Veriler yüklenirken hata oluştu.", false);
        }
    }

    private void InitializeWorkingHours()
    {
        workingHours = new List<WorkingHoursViewModel>();
        var days = Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().ToList();
        var sortedDays = days.OrderBy(d => d == DayOfWeek.Sunday ? 7 : (int)d).ToList();
        foreach (DayOfWeek day in sortedDays)
        {
            var wh = salon?.WorkingHours.FirstOrDefault(w => w.DayOfWeek == day);
            workingHours.Add(new WorkingHoursViewModel
            {
                DayOfWeek = day,
                OpeningTime = wh?.OpeningTime ?? new TimeOnly(9, 0),
                ClosingTime = wh?.ClosingTime ?? new TimeOnly(18, 0),
                IsClosed = wh?.IsClosed ?? (day == DayOfWeek.Sunday)
            });
        }
    }
    
    private async Task ShowStatusMessage(string message, bool success)
    {
        statusMessage = message;
        isSuccess = success;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(3000); 
        statusMessage = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddService()
    {
        if (salon is not null && !string.IsNullOrWhiteSpace(newService.Name))
        {
            isProcessing = true;
            processingMessage = "Hizmet ekleniyor...";
            StateHasChanged();
            try
            {
                newService.SalonId = salon.Id;
                DbContext.Services.Add(newService);
                await DbContext.SaveChangesAsync();
                newService = new();
                await LoadSalon();
                isProcessing = false;
                await ShowStatusMessage("Hizmet eklendi.", true);
            }
            catch (Exception ex) 
            { 
                isProcessing = false;
                await ShowStatusMessage($"Hata: {ex.Message}", false); 
            }
        }
    }
    
    private async Task UpdateService(Service service)
    {
        isProcessing = true;
        processingMessage = "Hizmet güncelleniyor...";
        StateHasChanged();
        try
        {
            var serviceToUpdate = await DbContext.Services.FindAsync(service.Id);
            if(serviceToUpdate != null)
            {
                serviceToUpdate.Name = service.Name;
                serviceToUpdate.Price = service.Price;
                serviceToUpdate.DurationInMinutes = service.DurationInMinutes;
                await DbContext.SaveChangesAsync();
                await LoadSalon();
                isProcessing = false;
                await ShowStatusMessage("Hizmet güncellendi.", true);
            }
            else
            {
                isProcessing = false;
            }
        }
        catch (Exception ex) 
        { 
            isProcessing = false;
            await ShowStatusMessage($"Hata: {ex.Message}", false); 
        }
    }

    private async Task DeleteService(int serviceId)
    {
        isProcessing = true;
        processingMessage = "Hizmet siliniyor...";
        StateHasChanged();
        try
        {
            var service = await DbContext.Services.FindAsync(serviceId);
            if (service is not null)
            {
                DbContext.Services.Remove(service);
                await DbContext.SaveChangesAsync();
                await LoadSalon();
                isProcessing = false;
                await ShowStatusMessage("Hizmet silindi.", true);
            }
            else
            {
                isProcessing = false;
            }
        }
        catch (Exception ex) 
        { 
            isProcessing = false;
            await ShowStatusMessage($"Hata: {ex.Message}", false); 
        }
    }

    private async Task OnEmployeeImageSelected(InputFileChangeEventArgs e)
    {
        await OpenCropModal(e.File, "employee", 1.0); // 1:1 aspect ratio for employee photo
    }

    private async Task OnBackgroundFileSelected(InputFileChangeEventArgs e)
    {
        await OpenCropModal(e.File, "background", 0.5625); // 9:16 vertical ratio for mobile wallpaper style background
    }

    private async Task OnLogoFileSelected(InputFileChangeEventArgs e)
    {
        await OpenCropModal(e.File, "logo", 1.0); // 1:1 aspect ratio for profile picture / logo
    }

    private async Task OnBannerFileSelected(InputFileChangeEventArgs e)
    {
        await OpenCropModal(e.File, "banner", 3.0); // 3:1 landscape ratio for banner
    }

    private async Task OnImageFileSelected(InputFileChangeEventArgs e)
    {
        await OpenCropModal(e.File, "gallery", null); // Free aspect ratio for gallery photos
    }

    private async Task AddEmployee()
    {
        if (salon is not null && !string.IsNullOrWhiteSpace(newEmployee.Name))
        {
            isProcessing = true;
            processingMessage = "Uzman ekleniyor...";
            StateHasChanged();
            try
            {
                newEmployee.SalonId = salon.Id;
                DbContext.Employees.Add(newEmployee);
                await DbContext.SaveChangesAsync();
                newEmployee = new();
                await LoadSalon();
                isProcessing = false;
                await ShowStatusMessage("Uzman eklendi.", true);
            }
            catch (Exception ex) 
            { 
                isProcessing = false;
