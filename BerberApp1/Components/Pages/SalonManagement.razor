    // Generic Crop helpers
    private async Task OpenCropModal(IBrowserFile file, string target, double? aspectRatio)
    {
        if (file == null) return;
        if (file.Size > 1 * 1024 * 1024)
        {
            await ShowStatusMessage("Hata: Yüklemek istediğiniz görsel en fazla 1 MB olmalıdır.", false);
            return;
        }

        isProcessing = true;
        processingMessage = "Görsel yükleniyor ve hazırlanıyor...";
        StateHasChanged();

        cropTarget = target;
        cropAspectRatio = aspectRatio;

        try
        {
            var buffer = new byte[file.Size];
            using (var stream = file.OpenReadStream(1 * 1024 * 1024))
            {
                await stream.ReadExactlyAsync(buffer);
            }
            var base64 = Convert.ToBase64String(buffer);
            var extension = Path.GetExtension(file.Name).Replace(".", "").ToLower();
            if (extension == "jpg" || extension == "jpeg") extension = "jpeg";
            else if (extension != "png" && extension != "gif" && extension != "webp") extension = "png"; // fallback
            
            cropImageSourceUrl = $"data:image/{extension};base64,{base64}";
            isCropModalVisible = true;
            isCropInitializing = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ShowStatusMessage($"Görsel okunurken hata oluştu: {ex.Message}", false);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmCrop()
    {
        isCroppingInProgress = true;
        isProcessing = true;
        processingMessage = "Görsel işleniyor ve kaydediliyor...";
        StateHasChanged();
        try
        {
            int targetWidth = 400;
            int targetHeight = 400;
            if (cropTarget == "banner")
            {
                targetWidth = 1200;
                targetHeight = 400;
            }
            else if (cropTarget == "background")
            {
                targetWidth = 1080;
                targetHeight = 1920;
            }
            else if (cropTarget == "gallery")
            {
                targetWidth = 800;
                targetHeight = 600;
            }

            var croppedDataUrl = await JSRuntime.InvokeAsync<string>("bookingInterop.getCroppedImage", targetWidth, targetHeight);
            if (string.IsNullOrEmpty(croppedDataUrl))
            {
                await ShowStatusMessage("Görsel kırpılırken bir hata oluştu.", false);
                return;
            }

            var base64Data = croppedDataUrl.Substring(croppedDataUrl.IndexOf(",") + 1);
            var imageBytes = Convert.FromBase64String(base64Data);

            var fileName = $"{cropTarget}_{Guid.NewGuid()}.jpg";
            var storagePath = $"{cropTarget}s/{fileName}";
            if (cropTarget == "gallery")
            {
                storagePath = $"gallery/{fileName}";
            }

            var publicUrl = await FileStorageService.UploadFileAsync(imageBytes, storagePath, "image/jpeg");

            if (cropTarget == "employee")
            {
                if (!string.IsNullOrEmpty(newEmployee.PictureUrl))
                {
                    await FileStorageService.DeleteFileAsync(newEmployee.PictureUrl);
                }
                newEmployee.PictureUrl = publicUrl;
                await ShowStatusMessage("Uzman fotoğrafı başarıyla kırpıldı.", true);
            }
            else if (cropTarget == "logo" && salon != null)
            {
                var s = await DbContext.Salons.FindAsync(salon.Id);
                if (s != null)
                {
                    if (!string.IsNullOrEmpty(s.LogoUrl))
                    {
                        await FileStorageService.DeleteFileAsync(s.LogoUrl);
                    }
                    s.LogoUrl = publicUrl;
                    await DbContext.SaveChangesAsync();
                    await LoadSalon();
                    await ShowStatusMessage("Profil fotoğrafı güncellendi.", true);
                }
            }
            else if (cropTarget == "banner" && salon != null)
            {
                var s = await DbContext.Salons.FindAsync(salon.Id);
                if (s != null)
                {
                    if (!string.IsNullOrEmpty(s.BannerUrl))
                    {
                        await FileStorageService.DeleteFileAsync(s.BannerUrl);
                    }
                    s.BannerUrl = publicUrl;
                    await DbContext.SaveChangesAsync();
                    await LoadSalon();
                    await ShowStatusMessage("Kapak fotoğrafı güncellendi.", true);
                }
            }
            else if (cropTarget == "background" && salon != null)
            {
                var s = await DbContext.Salons.FindAsync(salon.Id);
                if (s != null)
                {
                    if (!string.IsNullOrEmpty(s.BackgroundUrl))
                    {
                        await FileStorageService.DeleteFileAsync(s.BackgroundUrl);
                    }
                    s.BackgroundUrl = publicUrl;
                    await DbContext.SaveChangesAsync();
                    await LoadSalon();
                    await ShowStatusMessage("Arka plan görseli güncellendi.", true);
                }
            }
            else if (cropTarget == "gallery" && salon != null)
            {
                var newImage = new SalonImage { SalonId = salon.Id, ImageUrl = publicUrl };
                DbContext.SalonImages.Add(newImage);
                await DbContext.SaveChangesAsync();
                await LoadSalon();
                await ShowStatusMessage("Görsel galeriye eklendi.", true);
            }
        }
        catch (Exception ex)
        {
            await ShowStatusMessage($"Kırpma işlemi başarısız oldu: {ex.Message}", false);
        }
        finally
        {
            isProcessing = false;
            await CancelCrop();
        }
    }

    private async Task CancelCrop()
    {
        isCropModalVisible = false;
        cropImageSourceUrl = "";
        isCropInitializing = false;
        isCroppingInProgress = false;
        isProcessing = false;
        await JSRuntime.InvokeVoidAsync("bookingInterop.destroyCropper");
    }
