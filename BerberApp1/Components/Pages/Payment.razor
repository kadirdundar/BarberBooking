@page "/payment"

<div class="payment-container">
    <h2 class="section-title">Planınızı Seçin</h2>
    <p class="section-subtitle">İşletmeniz için en uygun planı seçerek dijital dönüşüme başlayın.</p>
    <div class="pricing-grid">
        <!-- Free Plan -->
        <div class="pricing-card">
            <div class="pricing-header">
                <h3>Free Plan</h3>
                <p>Başlangıç için temel özellikler</p>
            </div>
            <div class="pricing-price">
                <sup>$</sup>0<span>/ay</span>
            </div>
            <ul class="pricing-features">
                <li><i class="fas fa-check"></i> 1 Kullanıcı</li>
                <li><i class="fas fa-check"></i> 50 Randevu/ay</li>
                <li><i class="fas fa-check"></i> Temel Raporlama</li>
                <li><i class="fas fa-times"></i> SMS Bildirimleri</li>
                <li><i class="fas fa-times"></i> Öncelikli Destek</li>
            </ul>
            <div class="pricing-footer">
                <a href="#" class="btn btn-secondary">Planı Seç</a>
            </div>
        </div>

        <!-- Standard Plan -->
        <div class="pricing-card popular">
            <div class="popular-badge">Popüler</div>
            <div class="pricing-header">
                <h3>Standard Plan</h3>
                <p>Büyüyen işletmeler için ideal</p>
            </div>
            <div class="pricing-price">
                <sup>$</sup>49<span>/ay</span>
            </div>
            <ul class="pricing-features">
                <li><i class="fas fa-check"></i> 5 Kullanıcı</li>
                <li><i class="fas fa-check"></i> 500 Randevu/ay</li>
                <li><i class="fas fa-check"></i> Gelişmiş Raporlama</li>
                <li><i class="fas fa-check"></i> SMS Bildirimleri</li>
                <li><i class="fas fa-times"></i> Öncelikli Destek</li>
            </ul>
            <div class="pricing-footer">
                <a href="#" class="btn btn-primary">Planı Seç</a>
            </div>
        </div>

        <!-- Pro Plan -->
        <div class="pricing-card">
            <div class="pricing-header">
                <h3>Pro Plan</h3>
                <p>Tüm özellikler ve öncelikli destek</p>
            </div>
            <div class="pricing-price">
                <sup>$</sup>99<span>/ay</span>
            </div>
            <ul class="pricing-features">
                <li><i class="fas fa-check"></i> Sınırsız Kullanıcı</li>
                <li><i class="fas fa-check"></i> Sınırsız Randevu</li>
                <li><i class="fas fa-check"></i> Detaylı Raporlama</li>
                <li><i class="fas fa-check"></i> SMS Bildirimleri</li>
                <li><i class="fas fa-check"></i> Öncelikli Destek</li>
            </ul>
            <div class="pricing-footer">
                <a href="#" class="btn btn-secondary">Planı Seç</a>
            </div>
        </div>
    </div>
</div>
