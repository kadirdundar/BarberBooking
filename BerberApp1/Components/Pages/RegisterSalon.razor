@page "/registersalon"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Security.Claims
@using BerberApp1.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>İşletme Kayıt Sihirbazı</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="register-salon-container">
            <div class="register-salon-header">
                <h2 class="section-title">Hoş Geldin, @authContext.User.Identity.Name!</h2>
                <p class="section-subtitle">Salonunuzu kurmak için aşağıdaki adımları tamamlayın.</p>
            </div>

            <div class="stepper-wrapper">
                <VerticalStepper CurrentStep="@currentStep" Steps="@steps" IsHorizontal="true" />
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert @(isSuccess ? "alert-success" : "alert-danger") shadow-sm mb-4" role="alert">
                    @statusMessage
                </div>
            }

            <div class="onboarding-card">
                @if (currentStep == 1)
                {
                    <div class="card-header-gradient">
                        <h3><i class="fas fa-store"></i> Adım 1: İşletme Bilgileri</h3>
                        <p>Salonunuzun temel iletişim ve tanıtım bilgilerini girin.</p>
                    </div>
                    <div class="card-body-content">
                        <EditForm EditContext="step1Context" OnValidSubmit="GoToStep2" class="needs-validation" Novalidate>
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-danger" />

                            <div class="mb-3">
                                <label for="name" class="form-label">İşletme Adı</label>
                                <InputText id="name" class="form-control" @bind-Value="@Salon.Name" placeholder="Örn: Kuaför Ahmet" />
                                <ValidationMessage For="@(() => Salon.Name)" />
                            </div>

                            <div class="mb-3">
                                <label for="nickname" class="form-label">Kullanıcı Adı (NickName)</label>
                                <div class="input-group">
                                    <span class="input-group-text">bookify.com/</span>
                                    <InputText id="nickname" class="form-control" @bind-Value="@Salon.NickName" @onfocusout="CheckNicknameAvailability" placeholder="salon-adiniz" />
                                </div>
                                <ValidationMessage For="@(() => Salon.NickName)" />
                                @if (!string.IsNullOrEmpty(nicknameAvailabilityMessage))
                                {
                                    <div class="form-text @nicknameAvailabilityClass mt-1 fw-bold">@nicknameAvailabilityMessage</div>
                                }
                            </div>

                            <div class="mb-3">
                                <label for="address" class="form-label">Adres</label>
                                <InputText id="address" class="form-control" @bind-Value="@Salon.Address" placeholder="İşletmenizin açık adresi" />
                                <ValidationMessage For="@(() => Salon.Address)" />
                            </div>

                            <div class="mb-3">
                                <label for="phone" class="form-label">Telefon Numarası</label>
                                <InputText id="phone" class="form-control" @bind-Value="@Salon.PhoneNumber" placeholder="05XXXXXXXXX" />
                                <ValidationMessage For="@(() => Salon.PhoneNumber)" />
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label">E-posta</label>
                                <InputText id="email" class="form-control" @bind-Value="@Salon.Email" placeholder="iletisim@salondomain.com" />
                                <ValidationMessage For="@(() => Salon.Email)" />
                            </div>

                            <div class="mb-3">
                                <label for="description" class="form-label">Açıklama</label>
                                <InputTextArea id="description" class="form-control" @bind-Value="@Salon.Description" rows="3" placeholder="Salonunuz hakkında kısa bir bilgi yazın..." />
                                <ValidationMessage For="@(() => Salon.Description)" />
                            </div>

                            <div class="wizard-actions">
                                <button type="submit" class="btn-wizard btn-wizard-next">
                                    Sonraki Adım <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        </EditForm>
                    </div>
                }
                else if (currentStep == 2)
                {
                    <div class="card-header-gradient">
                        <h3><i class="fas fa-clock"></i> Adım 2: Çalışma Saatleri</h3>
                        <p>Salonunuzun hangi gün ve saatlerde hizmet verdiğini belirleyin.</p>
                    </div>
                    <div class="card-body-content">
                        <div class="info-note">
                            <i class="fas fa-info-circle"></i>
                            <p><strong>Not:</strong> Çalışma saatlerinizi daha sonra dilediğiniz zaman işletme yönetim panelinizden güncelleyebilirsiniz.</p>
                        </div>

                        <div class="hours-list-container">
                            @foreach (var wh in workingHours)
                            {
                                <div class="day-row-card @(wh.IsClosed ? "closed" : "")">
                                    <div class="day-info">
                                        <span class="day-name">@GetDayNameTr(wh.DayOfWeek)</span>
                                        <span class="status-badge @(wh.IsClosed ? "closed" : "open")">
                                            @(wh.IsClosed ? "Kapalı" : "Açık")
                                        </span>
                                    </div>

                                    <div class="form-check form-switch m-0">
                                        <input class="form-check-input" type="checkbox" role="switch" checked="@(!wh.IsClosed)" @onchange="@(e => wh.IsClosed = !(bool)e.Value!)" id="switch-@wh.DayOfWeek" />
                                        <label class="form-check-label text-muted" for="switch-@wh.DayOfWeek">Durum</label>
                                    </div>

                                    <div class="time-selector-group">
                                        <input type="time" @bind="wh.OpeningTime" class="time-input" disabled="@wh.IsClosed" />
                                        <span class="time-separator">-</span>
                                        <input type="time" @bind="wh.ClosingTime" class="time-input" disabled="@wh.IsClosed" />
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="wizard-actions">
                            <button type="button" class="btn-wizard btn-wizard-prev" @onclick="GoBack">
                                <i class="fas fa-arrow-left"></i> Geri
                            </button>
                            <button type="button" class="btn-wizard btn-wizard-next" @onclick="GoToStep3">
                                Sonraki Adım <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                }
                else if (currentStep == 3)
                {
                    <div class="card-header-gradient">
                        <h3><i class="fas fa-cut"></i> Adım 3: Hizmetler</h3>
                        <p>Müşterilerinizin randevu alabileceği hizmetleri ekleyin.</p>
                    </div>
                    <div class="card-body-content">
                        <div class="info-note">
                            <i class="fas fa-info-circle"></i>
                            <p><strong>Not:</strong> Hizmetlerinizi, fiyatlarını ve sürelerini daha sonra dilediğiniz zaman güncelleyebilir veya yenilerini ekleyebilirsiniz.</p>
                        </div>

                        <div class="services-setup-container">
                            <div class="service-input-card">
                                <h5><i class="fas fa-plus-circle text-warning me-1"></i> Yeni Hizmet Ekle</h5>
                                <div class="row g-3">
                                    <div class="col-md-5">
                                        <label class="form-label">Hizmet Adı</label>
                                        <input type="text" @bind="newService.Name" class="form-control form-control-sm" placeholder="Örn: Saç Kesimi, Sakal Tıraşı" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Fiyat (TL)</label>
                                        <div class="input-group">
                                            <span class="input-group-text">₺</span>
                                            <input type="number" @bind="newService.Price" class="form-control" placeholder="150" />
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Süre (Dakika)</label>
                                        <div class="input-group">
                                            <input type="number" @bind="newService.DurationInMinutes" class="form-control" placeholder="30" />
                                            <span class="input-group-text">dk</span>
                                        </div>
                                    </div>
                                    <div class="col-md-1 d-flex align-items-end">
                                        <button type="button" class="btn btn-primary w-100 py-2" @onclick="AddServiceInMemory">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="services-list-container">
                                <h6>Eklenen Hizmetler (@services.Count)</h6>
                                @if (services.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="services-list-table">
                                            <thead>
                                                <tr>
                                                    <th>Hizmet Adı</th>
                                                    <th>Fiyat</th>
                                                    <th>Süre</th>
                                                    <th class="text-end">İşlem</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var service in services)
                                                {
                                                    <tr class="service-item-row">
                                                        <td>@service.Name</td>
                                                        <td>₺@service.Price</td>
                                                        <td>@service.DurationInMinutes dk</td>
                                                        <td class="text-end">
                                                            <button class="btn-delete-service" @onclick="() => RemoveServiceFromMemory(service)">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center p-4 border border-dashed rounded-3 bg-light text-muted">
                                        <i class="fas fa-info-circle mb-2" style="font-size: 1.5rem;"></i>
                                        <p class="m-0">Henüz hiçbir hizmet eklemediniz. En az bir hizmet eklemeniz önerilir.</p>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="wizard-actions">
                            <button type="button" class="btn-wizard btn-wizard-prev" @onclick="GoBack">
                                <i class="fas fa-arrow-left"></i> Geri
                            </button>
                            <button type="button" class="btn-wizard btn-wizard-next" @onclick="GoToStep4">
                                Sonraki Adım <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                }
                else if (currentStep == 4)
                {
                    <div class="card-header-gradient">
                        <h3><i class="fas fa-clipboard-check"></i> Adım 4: Özet ve Onay</h3>
                        <p>Bilgilerinizi kontrol edin ve kurulumu tamamlayın.</p>
                    </div>
                    <div class="card-body-content">
                        <div class="summary-container">
                            <div class="summary-section">
                                <h4><i class="fas fa-store"></i> İşletme Bilgileri</h4>
                                <div class="summary-grid">
                                    <div class="summary-item">
                                        <div class="summary-label">İşletme Adı</div>
                                        <div class="summary-value">@Salon.Name</div>
                                    </div>
                                    <div class="summary-item">
                                        <div class="summary-label">Kullanıcı Adı (NickName)</div>
                                        <div class="summary-value">@Salon.NickName</div>
                                    </div>
                                    <div class="summary-item">
                                        <div class="summary-label">Telefon</div>
                                        <div class="summary-value">@Salon.PhoneNumber</div>
                                    </div>
                                    <div class="summary-item">
                                        <div class="summary-label">E-posta</div>
                                        <div class="summary-value">@Salon.Email</div>
                                    </div>
                                    <div class="summary-item" style="grid-column: span 2;">
                                        <div class="summary-label">Adres</div>
                                        <div class="summary-value">@Salon.Address</div>
                                    </div>
                                </div>
                            </div>

                            <div class="summary-section">
                                <h4><i class="fas fa-clock"></i> Çalışma Saatleri</h4>
                                <div class="summary-hours-grid">
                                    @foreach (var wh in workingHours)
                                    {
                                        <div class="summary-hour-card">
                                            <span class="fw-bold">@GetDayNameTr(wh.DayOfWeek)</span>
                                            <span>
                                                @if (wh.IsClosed)
                                                {
                                                    <span class="text-danger">Kapalı</span>
                                                }
                                                else
                                                {
                                                    <span class="text-success">@wh.OpeningTime.ToString("HH:mm") - @wh.ClosingTime.ToString("HH:mm")</span>
                                                }
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="summary-section">
                                <h4><i class="fas fa-cut"></i> Hizmetler</h4>
                                @if (services.Any())
                                {
                                    <div class="summary-services-list">
                                        @foreach (var service in services)
                                        {
                                            <div class="summary-service-tag">
                                                <span class="summary-service-name">@service.Name</span>
                                                <span class="summary-service-details">₺@service.Price | @service.DurationInMinutes dk</span>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted italic">Eklenen hizmet bulunmuyor. Kurulumdan sonra yönetim panelinden hizmet ekleyebilirsiniz.</p>
                                }
                            </div>
                        </div>

                        <div class="wizard-actions">
                            <button type="button" class="btn-wizard btn-wizard-prev" @onclick="GoBack" disabled="@isSubmitting">
                                <i class="fas fa-arrow-left"></i> Geri
                            </button>
                            <button type="button" class="btn-wizard btn-wizard-next" @onclick="HandleRegistration" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Kaydediliyor...</span>
                                }
                                else
                                {
                                    <span>Kurulumu Tamamla</span> <i class="fas fa-check-circle"></i>
                                }
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "name")]
    public string? UrlSalonName { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "nickname")]
    public string? UrlNickname { get; set; }

    private Salon Salon { get; set; } = new Salon();
    private string statusMessage = string.Empty;
    private bool isSuccess;

    private string nicknameAvailabilityMessage = string.Empty;
    private string nicknameAvailabilityClass = string.Empty;
    private bool isNicknameChecking = false;

    // Wizard/Stepper States
    private int currentStep = 1;
    private bool isSubmitting = false;
    private EditContext? step1Context;

    private Dictionary<int, string> steps = new()
    {
        { 1, "İşletme Bilgileri" },
        { 2, "Çalışma Saatleri" },
        { 3, "Hizmetler" },
        { 4, "Özet ve Onay" }
    };

    // Step 2 Working Hours
    private List<WorkingHoursViewModel> workingHours = new();

    // Step 3 Services
    private List<Service> services = new();
    private Service newService = new() { DurationInMinutes = 30, Price = 100 };

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(UrlSalonName))
        {
            Salon.Name = UrlSalonName;
        }
        if (!string.IsNullOrEmpty(UrlNickname))
        {
            Salon.NickName = UrlNickname;
            await CheckNicknameAvailability();
        }
        
        step1Context = new EditContext(Salon);
        InitializeWorkingHours();
    }

    private void InitializeWorkingHours()
    {
        workingHours = new List<WorkingHoursViewModel>();
        var days = Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>().ToList();
        var sortedDays = days.OrderBy(d => d == DayOfWeek.Sunday ? 7 : (int)d).ToList();
        foreach (DayOfWeek day in sortedDays)
        {
            workingHours.Add(new WorkingHoursViewModel
            {
                DayOfWeek = day,
                OpeningTime = new TimeOnly(9, 0),
                ClosingTime = new TimeOnly(18, 0),
                IsClosed = day == DayOfWeek.Sunday
            });
        }
    }

    private string GetDayNameTr(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Pazartesi",
        DayOfWeek.Tuesday => "Salı",
        DayOfWeek.Wednesday => "Çarşamba",
        DayOfWeek.Thursday => "Perşembe",
        DayOfWeek.Friday => "Cuma",
        DayOfWeek.Saturday => "Cumartesi",
        DayOfWeek.Sunday => "Pazar",
        _ => day.ToString()
    };

    private async Task CheckNicknameAvailability()
    {
        if (string.IsNullOrWhiteSpace(Salon.NickName))
        {
            nicknameAvailabilityMessage = string.Empty;
            nicknameAvailabilityClass = string.Empty;
            return;
        }

        isNicknameChecking = true;
        nicknameAvailabilityMessage = "Kontrol ediliyor...";
        nicknameAvailabilityClass = "text-info";

        try
        {
            var cleanNick = Salon.NickName.Trim().ToLowerInvariant();
            Salon.NickName = cleanNick; // update model

            // Validate against reserved names
            var reservedNames = new[] { "register", "registersalon", "login", "logout", "business", "booking", "salon", "salon-management", "employee-timeline", "reports", "api", "admin", "home" };
            if (reservedNames.Contains(cleanNick))
            {
                nicknameAvailabilityMessage = "❌ Bu kullanıcı adı geçersiz (sistem tarafından ayrılmıştır).";
                nicknameAvailabilityClass = "text-danger";
                return;
            }

            // Regex check
            var regex = new System.Text.RegularExpressions.Regex(@"^[a-zA-Z0-9-_]+$");
            if (!regex.IsMatch(cleanNick))
            {
                nicknameAvailabilityMessage = "❌ Kullanıcı adı sadece harf, rakam, tire (-) ve alt çizgi (_) içerebilir.";
                nicknameAvailabilityClass = "text-danger";
                return;
            }

            var isTaken = await DbContext.Salons.AnyAsync(s => s.NickName == cleanNick);
            if (isTaken)
            {
                nicknameAvailabilityMessage = "❌ Bu kullanıcı adı zaten alınmış.";
                nicknameAvailabilityClass = "text-danger";
            }
            else
            {
                nicknameAvailabilityMessage = "✅ Bu kullanıcı adı kullanılabilir!";
                nicknameAvailabilityClass = "text-success";
            }
        }
        catch (Exception)
        {
            nicknameAvailabilityMessage = "Kontrol edilirken hata oluştu.";
            nicknameAvailabilityClass = "text-warning";
        }
        finally
        {
            isNicknameChecking = false;
        }
    }

    private async Task GoToStep2()
    {
        await CheckNicknameAvailability();
        if (nicknameAvailabilityClass == "text-danger" || string.IsNullOrWhiteSpace(Salon.NickName))
        {
            statusMessage = "Lütfen geçerli ve kullanılabilir bir kullanıcı adı (NickName) girin.";
            isSuccess = false;
            return;
        }

        statusMessage = string.Empty;
        currentStep = 2;
    }

    private void GoBack()
    {
        if (currentStep > 1)
        {
            currentStep--;
            statusMessage = string.Empty;
        }
    }

    private void GoToStep3()
    {
        statusMessage = string.Empty;
        currentStep = 3;
    }

    private void GoToStep4()
    {
        statusMessage = string.Empty;
        currentStep = 4;
    }

    private void AddServiceInMemory()
    {
        if (string.IsNullOrWhiteSpace(newService.Name))
        {
            statusMessage = "Hizmet adı boş bırakılamaz.";
            isSuccess = false;
            return;
        }
        if (newService.Price < 0)
        {
            statusMessage = "Fiyat sıfırdan küçük olamaz.";
            isSuccess = false;
            return;
        }
        if (newService.DurationInMinutes <= 0)
        {
            statusMessage = "Süre sıfırdan büyük olmalıdır.";
            isSuccess = false;
            return;
        }

        services.Add(new Service
        {
            Name = newService.Name,
            Price = newService.Price,
            DurationInMinutes = newService.DurationInMinutes,
            Description = string.Empty
        });

        // Reset inputs
        newService = new Service { DurationInMinutes = 30, Price = 100 };
        statusMessage = string.Empty;
    }

    private void RemoveServiceFromMemory(Service service)
    {
        services.Remove(service);
    }

    private async Task HandleRegistration()
    {
        isSubmitting = true;
        statusMessage = "İşletme kaydediliyor...";
        isSuccess = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity.IsAuthenticated)
        {
            await CheckNicknameAvailability();
            if (nicknameAvailabilityClass == "text-danger")
            {
                isSuccess = false;
                statusMessage = nicknameAvailabilityMessage.Replace("❌ ", "");
                isSubmitting = false;
                return;
            }

            if (string.IsNullOrWhiteSpace(Salon.NickName))
            {
                isSuccess = false;
                statusMessage = "Kullanıcı adı (NickName) boş bırakılamaz.";
                isSubmitting = false;
                return;
            }

            var googleId = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
            var email = user.FindFirst(c => c.Type == ClaimTypes.Email)?.Value;
            var name = user.FindFirst(c => c.Type == ClaimTypes.Name)?.Value;

            var dbUser = await DbContext.Users.FirstOrDefaultAsync(u => u.GoogleId == googleId);
            if (dbUser == null)
            {
                dbUser = new User { GoogleId = googleId, Email = email, Name = name };
                DbContext.Users.Add(dbUser);
                await DbContext.SaveChangesAsync();
            }

            Salon.UserId = dbUser.Id;

            // Use transaction to save all related entities safely
            using var transaction = await DbContext.Database.BeginTransactionAsync();
            try
            {
                DbContext.Salons.Add(Salon);
                await DbContext.SaveChangesAsync();

                // Save Working Hours
                foreach (var wh in workingHours)
                {
                    var workingHour = new SalonWorkingHours
                    {
                        SalonId = Salon.Id,
                        DayOfWeek = wh.DayOfWeek,
                        OpeningTime = wh.OpeningTime,
                        ClosingTime = wh.ClosingTime,
                        IsClosed = wh.IsClosed
                    };
                    DbContext.SalonWorkingHours.Add(workingHour);
                }

                // Save Services
                foreach (var service in services)
                {
                    service.SalonId = Salon.Id;
                    DbContext.Services.Add(service);
                }

                await DbContext.SaveChangesAsync();
                await transaction.CommitAsync();

                isSuccess = true;
                statusMessage = "İşletme başarıyla kaydedildi!";
                
                NavigationManager.NavigateTo($"/salon-management/{Salon.Id}");
            }
            catch (Exception ex)
            {
                await transaction.RollbackAsync();
                isSuccess = false;
                statusMessage = $"İşletme kaydedilirken bir hata oluştu: {ex.Message}";
                Console.WriteLine($"Error saving salon: {ex.Message}");
            }
            finally
            {
                isSubmitting = false;
            }
        }
        else
        {
            isSuccess = false;
            statusMessage = "Yetkilendirme hatası. Lütfen tekrar giriş yapın.";
            isSubmitting = false;
        }
    }
}