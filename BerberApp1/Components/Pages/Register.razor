@page "/register"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject NavigationManager NavigationManager

<div class="register-container">
    <div class="register-left">
        <div class="brand-logo">
            <a href="/">BarberBooking</a>
        </div>
        <h1>Salonunuzu Dijital Dünyaya Taşıyın</h1>
        <p>Binlerce başarılı salon arasına katılın. Müşteri yönetimi, online randevular ve daha fazlası parmaklarınızın ucunda.</p>
        <div class="testimonial">
            <blockquote>
                "BarberBooking sayesinde randevu trafiğimiz %40 azaldı ve müşteri memnuniyetimiz tavan yaptı. Kesinlikle tavsiye ederim!"
            </blockquote>
            <cite>– Ahmet Yılmaz, Modern Erkek Kuaförü</cite>
        </div>
    </div>
    <div class="register-right">
        <div class="register-form">
            <h2>Hesap Oluşturun</h2>
            <p>Başlamak için sadece bir dakikanızı ayırın.</p>
            <a href="api/auth/login?returnUrl=@(GetReturnUrl())" class="btn btn-google">
                <i class="fab fa-google"></i> Google ile Devam Et
            </a>
            <div class="login-prompt">
                <p>Zaten bir hesabınız var mı? <a href="/login">Giriş Yapın</a></p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "salonName")]
    public string? SalonName { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "nickname")]
    public string? NickName { get; set; }

    private string GetReturnUrl()
    {
        var queryParams = new List<string>();
        if (!string.IsNullOrEmpty(SalonName))
        {
            queryParams.Add($"name={Uri.EscapeDataString(SalonName)}");
        }
        if (!string.IsNullOrEmpty(NickName))
        {
            queryParams.Add($"nickname={Uri.EscapeDataString(NickName)}");
        }
        var queryString = queryParams.Any() ? "?" + string.Join("&", queryParams) : "";
        return $"/registersalon{queryString}";
    }
}